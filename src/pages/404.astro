---
import Base from '../layouts/Base.astro'
---

<Base title="Page not found">
  <div class="min-h-[60vh] flex flex-col items-center justify-center gap-4">
    <h1 class="font-serif text-6xl font-medium tracking-[-0.04em] text-accent">404</h1>
    <p class="text-lg text-ink-soft mb-4">The page you're looking for doesn't exist.</p>
    <a class="btn btn-primary" href="/">Return home →</a>
  </div>
</Base>
