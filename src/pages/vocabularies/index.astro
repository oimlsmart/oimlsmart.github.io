---
import { getEntry } from 'astro:content'
import { render } from 'astro:content'
import Base from '../../layouts/Base.astro'
import PageHero from '../../components/PageHero.astro'
import DraftCallout from '../../components/DraftCallout.astro'

const entry = await getEntry('pages', 'vocabularies')
const { Content } = await render(entry)
const { title, description, eyebrow } = entry.data
---

<Base title={title} description={description}>
  <article class="prose">
    <PageHero title={title} lede={description} eyebrow={eyebrow} />
    <DraftCallout />
    <Content />
  </article>
</Base>
