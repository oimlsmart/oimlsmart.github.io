---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import PageHero from '../../components/PageHero.astro'
import DraftCallout from '../../components/DraftCallout.astro'
import SITE from '../../data/site-meta'

const posts = (await getCollection('blog'))
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date))

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric',
  })
}
---

<Base title="OIML SMART pilot — updates" description={SITE.feedDescription}>
  <article class="prose">
    <PageHero eyebrow="Blog · Internal pilot feed" title="OIML SMART pilot — updates" lede={SITE.feedDescription} />
    <DraftCallout />
    <div class="blog-list">
      {posts.map(post => (
        <article class="blog-entry">
          <div class="blog-meta">
            <time>{formatDate(post.data.date)}</time>
            <span class="blog-author">{post.data.author}</span>
          </div>
          <h2><a href={`/blog/${post.id.replace('.md', '')}`}>{post.data.title}</a></h2>
          <p>{post.data.summary}</p>
          <a href={`/blog/${post.id.replace('.md', '')}`} class="blog-read">Read →</a>
        </article>
      ))}
    </div>
  </article>
</Base>

<style>
.blog-list { display: flex; flex-direction: column; gap: 1.5rem; margin: 2rem 0; }
.blog-entry {
  padding: 1.75rem; background: var(--vp-c-bg-soft);
  border: 1px solid var(--vp-c-divider); border-radius: 6px;
  transition: border-color 0.2s, transform 0.2s;
}
.blog-entry:hover { border-color: var(--vp-c-brand-1); transform: translateY(-2px); }
.blog-meta {
  display: flex; gap: 1rem; font-family: monospace;
  font-size: 0.75rem; color: var(--vp-c-text-3); margin-bottom: 0.75rem;
}
.blog-entry h2 { font-family: var(--vp-font-family-serif); font-size: 1.5rem; margin: 0 0 0.5rem; }
.blog-entry h2 a { color: var(--vp-c-text-1); text-decoration: none; }
.blog-entry h2 a:hover { color: var(--vp-c-brand-1); }
.blog-entry p { font-size: 0.9375rem; color: var(--vp-c-text-2); margin: 0 0 1rem; }
.blog-read { font-family: monospace; font-size: 0.8125rem; color: var(--vp-c-brand-1); text-decoration: none; }
.blog-read:hover { text-decoration: underline; }
</style>