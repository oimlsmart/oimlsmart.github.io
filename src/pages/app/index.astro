---
import Base from '../../layouts/Base.astro'
import SampleDataSeeder from '../../components/workflow/SampleDataSeeder.vue'

const title = 'OIML SMART Application'
const description = 'The OIML SMART certification workflow application.'
---

<Base title={title} description={description}>
  <SampleDataSeeder client:load />
  <div class="max-w-[900px] mx-auto py-12 px-6">
    <h1 class="font-serif text-3xl mb-2">SMART Application</h1>
    <p class="text-ink-soft mb-8">The certification workflow application.</p>

    <nav class="flex flex-col gap-3">
      <a href="/app/dispatch" class="group grid grid-cols-[2rem_1fr] gap-4 p-4 px-5 border border-rule rounded no-underline text-inherit transition-colors hover:border-accent hover:bg-paper-soft">
        <span class="font-mono text-xs text-ink-soft">01</span>
        <span class="font-medium">Dispatch Test Request</span>
        <span class="col-start-2 text-[0.8125rem] text-ink-soft">Outsource tests to labs with per-form granularity.</span>
      </a>
      <a href="/app/applications" class="group grid grid-cols-[2rem_1fr] gap-4 p-4 px-5 border border-rule rounded no-underline text-inherit transition-colors hover:border-accent hover:bg-paper-soft">
        <span class="font-mono text-xs text-ink-soft">02</span>
        <span class="font-medium">Applications</span>
        <span class="col-start-2 text-[0.8125rem] text-ink-soft">Certification applications and their status.</span>
      </a>
      <a href="/app/test-requests" class="group grid grid-cols-[2rem_1fr] gap-4 p-4 px-5 border border-rule rounded no-underline text-inherit transition-colors hover:border-accent hover:bg-paper-soft">
        <span class="font-mono text-xs text-ink-soft">03</span>
        <span class="font-medium">Test Requests</span>
        <span class="col-start-2 text-[0.8125rem] text-ink-soft">View all dispatched test requests and their status.</span>
      </a>
      <a href="/app/lab-inbox" class="group grid grid-cols-[2rem_1fr] gap-4 p-4 px-5 border border-rule rounded no-underline text-inherit transition-colors hover:border-accent hover:bg-paper-soft">
        <span class="font-mono text-xs text-ink-soft">04</span>
        <span class="font-medium">Lab Inbox</span>
        <span class="col-start-2 text-[0.8125rem] text-ink-soft">Test laboratory's incoming work queue.</span>
      </a>
      <a href="/app/evaluations" class="group grid grid-cols-[2rem_1fr] gap-4 p-4 px-5 border border-rule rounded no-underline text-inherit transition-colors hover:border-accent hover:bg-paper-soft">
        <span class="font-mono text-xs text-ink-soft">05</span>
        <span class="font-medium">Evaluations</span>
        <span class="col-start-2 text-[0.8125rem] text-ink-soft">3-level synthesis: TestReport → Model → Family decisions.</span>
      </a>
      <a href="/app/model-families" class="group grid grid-cols-[2rem_1fr] gap-4 p-4 px-5 border border-rule rounded no-underline text-inherit transition-colors hover:border-accent hover:bg-paper-soft">
        <span class="font-mono text-xs text-ink-soft">06</span>
        <span class="font-medium">Model Families</span>
        <span class="col-start-2 text-[0.8125rem] text-ink-soft">Instrument model family catalog.</span>
      </a>
      <a href="/app/samples" class="group grid grid-cols-[2rem_1fr] gap-4 p-4 px-5 border border-rule rounded no-underline text-inherit transition-colors hover:border-accent hover:bg-paper-soft">
        <span class="font-mono text-xs text-ink-soft">07</span>
        <span class="font-medium">Sample Inventory</span>
        <span class="col-start-2 text-[0.8125rem] text-ink-soft">Instrument samples and their custody status.</span>
      </a>
      <a href="/app/certificates" class="group grid grid-cols-[2rem_1fr] gap-4 p-4 px-5 border border-rule rounded no-underline text-inherit transition-colors hover:border-accent hover:bg-paper-soft">
        <span class="font-mono text-xs text-ink-soft">08</span>
        <span class="font-medium">Certificates</span>
        <span class="col-start-2 text-[0.8125rem] text-ink-soft">OIML certificates issued from finalized evaluations.</span>
      </a>
      <a href="/login/" class="group grid grid-cols-[2rem_1fr] gap-4 p-4 px-5 border border-rule rounded no-underline text-inherit transition-colors hover:border-accent hover:bg-paper-soft">
        <span class="font-mono text-xs text-ink-soft">↗</span>
        <span class="font-medium">Sign in</span>
        <span class="col-start-2 text-[0.8125rem] text-ink-soft">Authenticate via GitHub OAuth.</span>
      </a>
    </nav>

    <p class="mt-12 p-4 border-l-[3px] border-accent bg-paper-soft text-[0.8125rem]">
      <strong>Note:</strong> This is the unified Astro deployment of the SMART app.
      The legacy standalone app is at <code>smart/browser/</code> (see ARCHIVED.md).
      Workflow pages are being migrated incrementally per TODO.astro.
    </p>
  </div>
</Base>
