---
import Base from '../../layouts/Base.astro'
const APP_URL = import.meta.env.APP_URL || 'http://localhost:5190'
const title = 'Opening OIML SMART…'
const description = `Launcher for the OIML SMART application at ${APP_URL}.`
---

<Base title={title} description={description}>
  <meta slot="head" http-equiv="refresh" content={`0;url=${APP_URL}`} />
  <script is:inline define:vars={{ APP_URL }}>
    window.location.replace(APP_URL)
  </script>
  <div class="min-h-[calc(100vh-4rem)] flex items-center justify-center p-12 px-4">
    <div class="bg-paper-soft border border-rule rounded-lg p-8 max-w-[480px] w-full text-center">
      <h1 class="font-serif text-2xl mb-4">Opening the OIML SMART app…</h1>
      <p class="text-[0.9375rem] text-ink-soft mb-3">If you are not redirected automatically, <a href={APP_URL} class="text-accent underline">open {APP_URL}</a> manually.</p>
      <p class="mt-6 pt-5 border-t border-dashed border-rule text-xs text-ink-muted">
        Requires the smart app running locally. From the <code>smart</code> repo, run <code>bin/dev</code>.
        Not signed in yet? <a href="/login/" class="text-accent underline">Sign in</a>.
      </p>
    </div>
  </div>
</Base>
