---
import { ontologyEntities, ontologyNamespaces } from '../../data/ontology-data'
import Base from '../../layouts/Base.astro'
import OntologyDetail from '../../components/ontology/OntologyDetail.vue'

export async function getStaticPaths() {
  const knownPrefixes = new Set((ontologyNamespaces as readonly { prefix: string }[]).map((n) => n.prefix))
  return ontologyEntities
    .filter((entity) => knownPrefixes.has(entity.ontology))
    .map((entity) => ({
      params: { slug: entity.slug },
      props: { slug: entity.slug },
    }))
}

const { slug } = Astro.props
---

<Base title="Ontology" description="OIML semantic ontology entity detail.">
  <OntologyDetail client:load slug={slug} />
</Base>
