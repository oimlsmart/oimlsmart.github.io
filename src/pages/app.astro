---
import Base from '../layouts/Base.astro'
const APP_URL = import.meta.env.APP_URL || 'http://localhost:5190'
const APP_HOST = APP_URL.replace(/^https?:\/\//, '')
const title = 'Opening OIML SMART…'
const description = `Launcher for the OIML SMART application at ${APP_HOST}.`
---

<Base title={title} description={description}>
  <meta slot="head" http-equiv="refresh" content={`0;url=${APP_URL}`} />
  <script is:inline define:vars={{ APP_URL }}>
    // Immediate redirect; meta refresh is the backup for no-JS clients.
    window.location.replace(APP_URL)
  </script>

  <div class="launch">
    <aside class="launch-aside" aria-hidden="true">
      <span class="aside-label">redirect</span>
      <span class="aside-target">{APP_HOST}</span>
      <div class="aside-pulse" />
    </aside>

    <main class="launch-main">
      <span class="launch-eyebrow">Establishing connection</span>
      <h1 class="launch-title">Opening the SMART application.</h1>
      <p class="launch-lede">
        Your browser is being redirected to the local application server.
        If nothing happens, the server may not be running — see below.
      </p>

      <div class="launch-rule" />

      <a class="launch-open" href={APP_URL}>
        <span>Open {APP_HOST} manually</span>
        <span aria-hidden="true">→</span>
      </a>

      <div class="launch-note">
        <span class="note-key">Start the server</span>
        <div class="note-body">
          <p>From a clone of the <code>smart</code> repository:</p>
          <pre><code>$ bin/dev</code></pre>
          <p>The local server will listen at <a href={APP_URL}>{APP_HOST}</a>.</p>
        </div>
      </div>

      <footer class="launch-foot">
        <span>Not signed in?</span>
        <a href="/login/">Return to sign-in</a>
      </footer>
    </main>
  </div>
</Base>

<style>
.launch {
  min-height: calc(100vh - 64px);
  display: grid;
  grid-template-columns: minmax(180px, 0.8fr) minmax(0, 2.2fr);
}
@media (max-width: 800px) {
  .launch { grid-template-columns: 1fr; }
  .launch-aside { display: none; }
}

/* ── Aside: redirect indicator ───────────────────────────────── */
.launch-aside {
  position: relative;
  border-right: 1px solid var(--rule);
  background: var(--paper-soft);
  padding: 4rem 2rem;
  display: flex; flex-direction: column;
  gap: 0.5rem;
  overflow: hidden;
}
:global(.dark) .launch-aside { background: var(--paper-deep); }

.aside-label {
  font-family: var(--vp-font-family-mono, 'IBM Plex Mono', monospace);
  font-size: 0.625rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: color-mix(in srgb, var(--ink) 50%, transparent);
}
.aside-target {
  font-family: var(--vp-font-family-mono, 'IBM Plex Mono', monospace);
  font-size: 1rem;
  color: var(--accent);
  font-feature-settings: 'tnum';
  word-break: break-all;
}
.aside-pulse {
  position: absolute;
  bottom: 2rem; left: 2rem; right: 2rem;
  height: 2px;
  background: var(--rule);
  overflow: hidden;
}
.aside-pulse::after {
  content: '';
  position: absolute; inset: 0;
  background: var(--accent);
  transform-origin: left center;
  animation: pulse-fill 1.6s cubic-bezier(0.16, 1, 0.3, 1) infinite;
}

@keyframes pulse-fill {
  0%   { transform: scaleX(0); }
  60%  { transform: scaleX(1); }
  100% { transform: scaleX(1); opacity: 0; }
}

/* ── Main ────────────────────────────────────────────────────── */
.launch-main {
  padding: 5rem 4rem 3rem;
  max-width: 36rem;
}
@media (max-width: 1100px) { .launch-main { padding: 4rem 2.5rem 2.5rem; } }

.launch-eyebrow {
  display: inline-block;
  font-family: var(--vp-font-family-mono, 'IBM Plex Mono', monospace);
  font-size: 0.6875rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: color-mix(in srgb, var(--ink) 55%, transparent);
  margin-bottom: 1.5rem;
}

.launch-title {
  font-family: var(--vp-font-family-serif, 'Fraunces', serif);
  font-variation-settings: 'opsz' 96, 'wght' 400;
  font-size: clamp(2rem, 4vw, 2.75rem);
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin: 0 0 1.25rem;
}

.launch-lede {
  font-size: 1rem;
  line-height: 1.6;
  color: color-mix(in srgb, var(--ink) 75%, transparent);
  margin: 0 0 2rem;
  max-width: 30rem;
}

.launch-rule {
  height: 1px;
  background: var(--rule);
  margin: 0 0 2rem;
}

.launch-open {
  display: inline-flex; align-items: center; gap: 0.75rem;
  padding: 0.875rem 1.25rem;
  background: transparent;
  color: var(--ink);
  border: 1px solid var(--ink);
  border-radius: 2px;
  font-size: 0.9375rem;
  font-weight: 500;
  text-decoration: none;
  transition: background 200ms ease, color 200ms ease;
  margin-bottom: 2.5rem;
}
.launch-open:hover {
  background: var(--ink);
  color: var(--paper);
}
.launch-open > span:last-child {
  font-family: var(--vp-font-family-serif, 'Fraunces', serif);
  font-weight: 300;
  font-size: 1.125rem;
  transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
}
.launch-open:hover > span:last-child { transform: translateX(3px); }

/* ── Note: how to start the server ───────────────────────────── */
.launch-note {
  display: grid;
  grid-template-columns: 5rem 1fr;
  gap: 1rem;
  padding-top: 1.5rem;
  border-top: 1px dashed var(--rule);
}
.note-key {
  font-family: var(--vp-font-family-mono, 'IBM Plex Mono', monospace);
  font-size: 0.625rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: color-mix(in srgb, var(--ink) 50%, transparent);
  padding-top: 0.25rem;
}
.note-body {
  font-size: 0.875rem;
  line-height: 1.6;
  color: color-mix(in srgb, var(--ink) 75%, transparent);
}
.note-body p { margin: 0 0 0.5rem; }
.note-body p:last-child { margin-bottom: 0; }
.note-body code {
  font-family: var(--vp-font-family-mono, 'IBM Plex Mono', monospace);
  font-size: 0.75rem;
  background: color-mix(in srgb, var(--rule) 50%, transparent);
  padding: 1px 5px;
  border-radius: 2px;
}
.note-body pre {
  margin: 0.5rem 0 1rem;
  padding: 0.75rem 1rem;
  background: var(--paper-soft);
  border-left: 2px solid var(--accent);
  border-radius: 2px;
  font-family: var(--vp-font-family-mono, 'IBM Plex Mono', monospace);
  font-size: 0.8125rem;
  color: var(--ink);
}
:global(.dark) .note-body pre { background: var(--paper-deep); }
.note-body pre code { background: none; padding: 0; }
.note-body a {
  color: var(--accent);
  text-decoration: underline;
  text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
  text-underline-offset: 2px;
}

/* ── Footer ──────────────────────────────────────────────────── */
.launch-foot {
  display: flex; gap: 0.5rem; align-items: center;
  margin-top: 2.5rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--rule);
  font-family: var(--vp-font-family-mono, 'IBM Plex Mono', monospace);
  font-size: 0.6875rem;
  letter-spacing: 0.04em;
  color: color-mix(in srgb, var(--ink) 55%, transparent);
}
.launch-foot a {
  color: var(--accent);
  text-decoration: underline;
  text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
  text-underline-offset: 2px;
}

@media (prefers-reduced-motion: reduce) {
  .aside-pulse::after { animation: none; opacity: 0.5; }
}
</style>
