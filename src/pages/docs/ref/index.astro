---
import { getCollection } from 'astro:content'
import DocsLayout from '../../../layouts/DocsLayout.astro'
import DraftCallout from '../../../components/DraftCallout.astro'
import { byDocsOrder } from '../../../lib/docs-sort'
const META: Record<string, {label:string,desc:string}> = {
  guides: { label: 'Developer Guides', desc: 'Narrative walkthroughs for authoring a SMART Recommendation.' },
  arch: { label: 'Architecture', desc: 'The six-layer entity model, design principles, and primitives.' },
  workflow: { label: 'Workflow', desc: 'The end-to-end certification process.' },
  specifications: { label: 'Formal Specifications', desc: 'The SMART_REQS normative specification set.' },
  ref: { label: 'Reference', desc: 'Schemas, types, syntax, and identifiers.' },
}

const section = 'ref'
const info = META[section]
const pages = (await getCollection('docs'))
  .filter(d => d.id.startsWith(section + '/'))
  .sort(byDocsOrder)
---

<DocsLayout title={info.label} description={info.desc}>
  <div class="mb-4">
    <h1 class="font-serif text-[clamp(1.5rem,3.5vw,2rem)] font-semibold tracking-[-0.025em]">{info.label}</h1>
    <p class="text-base leading-[1.5] text-ink-soft mt-2">{info.desc}</p>
  </div>
  <DraftCallout />
  <div class="mt-6">
    {pages.map(p => (
      <a class="group flex flex-col gap-0.5 py-3 border-b border-rule no-underline text-inherit transition-[padding] duration-150 hover:pl-2" href={'/docs/' + p.id}>
        <span class="font-serif text-[0.9375rem] font-semibold group-hover:text-accent">{p.data.shortTitle || p.data.title || p.id.split('/').pop()}</span>
        {p.data.description && <span class="text-[0.8125rem] text-ink-soft">{p.data.description}</span>}
      </a>
    ))}
  </div>
</DocsLayout>
