---
import { getCollection } from 'astro:content'
import DocsLayout from '../../../layouts/DocsLayout.astro'
import DraftCallout from '../../../components/DraftCallout.astro'

const META: Record<string, {label:string,desc:string}> = {
  guides: { label: 'Developer Guides', desc: 'Narrative walkthroughs for authoring a SMART Recommendation.' },
  arch: { label: 'Architecture', desc: 'The six-layer entity model, design principles, and primitives.' },
  workflow: { label: 'Workflow', desc: 'The end-to-end certification process.' },
  specifications: { label: 'Formal Specifications', desc: 'The SMART_REQS normative specification set.' },
  ref: { label: 'Reference', desc: 'Schemas, types, syntax, and identifiers.' },
}

const section = 'guides'
const info = META[section]
const pages = (await getCollection('docs'))
  .filter(d => d.id.startsWith(section + '/'))
  .sort((a, b) => {
    const ao = (a.data as any).order ?? 999
    const bo = (b.data as any).order ?? 999
    if (ao !== bo) return ao - bo
    return a.id.localeCompare(b.id)
  })
---

<DocsLayout title={info.label} description={info.desc}>
  <div class="sec-intro">
    <h1>{info.label}</h1>
    <p>{info.desc}</p>
  </div>
  <DraftCallout />
  <div class="sec-list">
    {pages.map(p => (
      <a class="sec-item" href={'/docs/' + p.id}>
        <span class="sec-item-title">{p.data.shortTitle || p.data.title || p.id.split('/').pop()}</span>
        {p.data.description && <span class="sec-item-desc">{p.data.description}</span>}
      </a>
    ))}
  </div>
</DocsLayout>

<style>
.sec-intro { margin-bottom: 1rem; }
.sec-intro h1 {
  font-family: var(--font-serif);
  font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 600;
  letter-spacing: -0.025em; margin: 0;
}
.sec-intro p {
  font-size: 1rem; line-height: 1.5; color: var(--ink-soft); margin-top: 0.5rem;
}
.sec-list { margin-top: 1.5rem; }
.sec-item {
  display: flex; flex-direction: column; gap: 0.125rem;
  padding: 0.75rem 0; border-bottom: 1px solid var(--rule);
  text-decoration: none; color: inherit;
  transition: padding-left 0.15s;
}
.sec-item:hover { padding-left: 0.5rem; }
.sec-item-title {
  font-family: var(--font-serif); font-size: 0.9375rem; font-weight: 600;
}
.sec-item:hover .sec-item-title { color: var(--accent); }
.sec-item-desc { font-size: 0.8125rem; color: var(--ink-soft); }
</style>
