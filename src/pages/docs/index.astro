---
import { getCollection } from 'astro:content'
import DocsLayout from '../../layouts/DocsLayout.astro'
import DraftCallout from '../../components/DraftCallout.astro'

const sections = [
  { key: 'guides', label: 'Developer Guides', desc: 'Narrative walkthroughs for authoring a SMART Recommendation.' },
  { key: 'arch', label: 'Architecture', desc: 'The six-layer entity model, design principles, and primitives.' },
  { key: 'workflow', label: 'Workflow', desc: 'The end-to-end certification process from application to certificate.' },
  { key: 'specifications', label: 'Formal Specifications', desc: 'The 11-document SMART_REQS normative specification set.' },
  { key: 'ref', label: 'Reference', desc: 'Schemas, types, syntax, and identifiers.' },
]

const allDocs = await getCollection('docs')
const counts = sections.map(s => allDocs.filter(d => d.id.startsWith(s.key + '/')).length)
---

<DocsLayout title="Developer documentation">
  <div class="hub-intro">
    <h1>Developer documentation</h1>
    <p>Everything a standards developer, software engineer, or technical evaluator needs to author, deploy, or integrate OIML SMART Recommendations.</p>
  </div>
  <DraftCallout />
  <div class="hub-grid">
    {sections.map((s, i) => (
      <a class="hub-card" href={`/docs/${s.key}/`}>
        <div class="hub-card-head">
          <h2>{s.label}</h2>
          <span class="hub-count">{counts[i]}</span>
        </div>
        <p>{s.desc}</p>
      </a>
    ))}
  </div>
</DocsLayout>

<style>
.hub-intro { margin-bottom: 1rem; }
.hub-intro h1 {
  font-family: var(--font-serif);
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 600; letter-spacing: -0.025em; margin: 0;
}
.hub-intro p {
  font-size: 1.0625rem; line-height: 1.6;
  color: var(--ink-soft); max-width: 36rem; margin-top: 0.75rem;
}
.hub-grid { margin-top: 2rem; display: flex; flex-direction: column; }
.hub-card {
  display: block; padding: 1.25rem 0;
  border-bottom: 1px solid var(--rule);
  text-decoration: none; color: inherit;
  transition: padding-left 0.15s;
}
.hub-card:hover { padding-left: 0.5rem; }
.hub-card-head {
  display: flex; align-items: baseline; justify-content: space-between;
}
.hub-card-head h2 {
  font-family: var(--font-serif);
  font-size: 1.125rem; font-weight: 600; margin: 0;
  transition: color 0.15s;
}
.hub-card:hover h2 { color: var(--accent); }
.hub-count {
  font-family: var(--font-mono);
  font-size: 0.6875rem; color: var(--ink-muted);
}
.hub-card p {
  font-size: 0.875rem; color: var(--ink-soft);
  margin: 0.25rem 0 0;
}
</style>