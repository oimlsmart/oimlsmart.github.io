---
import { getCollection } from 'astro:content'
import DocsLayout from '../../layouts/DocsLayout.astro'

const sections = [
  { key: 'guides', label: 'Developer Guides', desc: 'Narrative walkthroughs for authoring a SMART Recommendation.' },
  { key: 'arch', label: 'Architecture', desc: 'The six-layer entity model, design principles, and primitives.' },
  { key: 'workflow', label: 'Workflow', desc: 'The end-to-end certification process from application to certificate.' },
  { key: 'specifications', label: 'Formal Specifications', desc: 'The 11-document SMART_REQS normative specification set.' },
  { key: 'ref', label: 'Reference', desc: 'Schemas, types, syntax, and identifiers.' },
]

const allDocs = await getCollection('docs')
const counts = sections.map(s => allDocs.filter(d => d.id.startsWith(s.key + '/')).length)
---

<DocsLayout title="Developer documentation">
  <div class="mb-4">
    <h1 class="font-serif text-[clamp(1.75rem,4vw,2.5rem)] font-semibold tracking-[-0.025em]">Developer documentation</h1>
    <p class="text-[1.0625rem] leading-[1.6] text-ink-soft max-w-2xl mt-3">Everything a standards developer, software engineer, or technical evaluator needs to author, deploy, or integrate OIML SMART Recommendations.</p>
  </div>
  <div class="mt-8 flex flex-col">
    {sections.map((s, i) => (
      <a class="group block py-5 border-b border-rule no-underline text-inherit transition-[padding] duration-150 hover:pl-2" href={`/docs/${s.key}/`}>
        <div class="flex items-baseline justify-between">
          <h2 class="font-serif text-lg font-semibold transition-colors group-hover:text-accent">{s.label}</h2>
          <span class="font-mono text-[0.6875rem] text-ink-muted">{counts[i]}</span>
        </div>
        <p class="text-sm text-ink-soft mt-1">{s.desc}</p>
      </a>
    ))}
  </div>
</DocsLayout>
