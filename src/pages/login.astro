---
import Base from '../layouts/Base.astro'
const today = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' })
---

<Base title="Sign in to OIML SMART" description="Authenticate via GitHub OAuth to continue into the OIML SMART application.">
  <div class="entry">
    {/* ── Left margin: specimen panel ─────────────────────────── */}
    <aside class="specimen relative border-r border-rule pt-16 pb-8 px-8 bg-paper-soft dark:bg-paper-deep overflow-hidden" aria-hidden="true">
      <div class="specimen-grid" />
      <div class="specimen-meta">
        <span class="specimen-tag">OIML SMART</span>
        <span class="specimen-locus">Certification System</span>
        <span class="specimen-edition">Edition · pilot</span>
        <span class="specimen-date">{today}</span>
      </div>
      <div class="specimen-rule" />
      <div class="specimen-marks">
        <span>0</span><span>1</span><span>2</span><span>3</span><span>4</span><span>5</span>
      </div>
    </aside>

    {/* ── Right: the actual entry ─────────────────────────────── */}
    <main class="gate">
      <header class="gate-head">
        <span class="gate-eyebrow">Access · restricted</span>
        <h1 class="gate-title">Sign in to enter<br />the certification system.</h1>
        <p class="gate-lede">
          OIML SMART is currently operating as a closed pilot. Authentication
          is brokered through your GitHub identity; no separate credentials
          are issued.
        </p>
      </header>

      <div class="gate-rule" />

      <a class="enter" href="/api/auth/signin/github">
        <span class="enter-label">Continue with GitHub</span>
        <span class="enter-arrow">→</span>
        <span class="enter-meta">oauth · web flow</span>
      </a>

      <p class="gate-note">
        <span class="note-key">Requires</span>
        <span class="note-val">
          the SMART application running on this machine. From a clone of the
          <code>smart</code> repository, execute <code>bin/dev</code> in your
          terminal. The local server listens on
          <a href="/app/">www.oimlsmart.org/app</a>.
        </span>
      </p>

      <footer class="gate-foot">
        <span>Pilot programme · internal use only</span>
        <span aria-hidden="true">·</span>
        <a href="/about/what-is-smart">What is OIML SMART?</a>
      </footer>
    </main>
  </div>
</Base>

<style>
/* ── Layout: asymmetric two-column ───────────────────────────── */
.entry {
  min-height: calc(100vh - 64px);
  display: grid;
  grid-template-columns: minmax(180px, 0.8fr) minmax(0, 2.2fr);
  align-items: stretch;
}
@media (max-width: 800px) {
  .entry { grid-template-columns: 1fr; }
  .specimen { display: none; }
}

/* ── Left specimen panel ─────────────────────────────────────── */
.specimen-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(to right, transparent 0, transparent calc(100% - 1px), var(--rule) 100%),
    repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2rem,
      color-mix(in srgb, var(--rule) 60%, transparent) 2rem,
      color-mix(in srgb, var(--rule) 60%, transparent) calc(2rem + 1px)
    );
  background-size: 100% 100%, 100% 2rem;
  opacity: 0.5;
  pointer-events: none;
}

.specimen-meta {
  position: relative;
  display: flex; flex-direction: column;
  font-family: var(--font-mono);
  font-size: 0.6875rem;
  letter-spacing: 0.04em;
  color: var(--ink);
  gap: 0.25rem;
}
.specimen-tag { font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; }
.specimen-locus { color: var(--accent); }
.specimen-edition, .specimen-date {
  color: color-mix(in srgb, var(--ink) 60%, transparent);
  font-feature-settings: 'tnum';
}

.specimen-rule {
  position: absolute;
  left: 2rem; right: 2rem; bottom: 5rem;
  height: 1px;
  background: var(--rule);
  transform-origin: left center;
  animation: rule-draw 720ms cubic-bezier(0.16, 1, 0.3, 1) 80ms both;
}

.specimen-marks {
  position: absolute;
  left: 2rem; right: 2rem; bottom: 2rem;
  display: flex; justify-content: space-between;
  font-family: var(--font-mono);
  font-size: 0.625rem;
  color: color-mix(in srgb, var(--ink) 40%, transparent);
  font-feature-settings: 'tnum';
}
.specimen-marks::before,
.specimen-marks::after {
  content: ''; position: absolute; top: -1rem; height: 0.5rem;
  border-left: 1px solid var(--rule);
}
.specimen-marks span {
  position: relative;
}
.specimen-marks span::before {
  content: ''; position: absolute; top: -1rem; left: 50%;
  width: 1px; height: 0.5rem; background: var(--rule);
}

/* ── Right entry panel ───────────────────────────────────────── */
.gate {
  padding: 5rem 4rem 3rem;
  max-width: 36rem;
  display: flex; flex-direction: column;
  gap: 0;
}
@media (max-width: 1100px) { .gate { padding: 4rem 2.5rem 2.5rem; } }

.gate-eyebrow {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 0.6875rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: color-mix(in srgb, var(--ink) 55%, transparent);
  margin-bottom: 1.5rem;
  opacity: 0;
  animation: rise 560ms cubic-bezier(0.16, 1, 0.3, 1) 0ms forwards;
}

.gate-title {
  font-family: var(--font-serif);
  font-variation-settings: 'opsz' 96, 'wght' 400;
  font-size: clamp(2.25rem, 4.5vw, 3.25rem);
  line-height: 1.05;
  letter-spacing: -0.02em;
  margin: 0 0 1.5rem;
  color: var(--ink);
  opacity: 0;
  animation: rise 640ms cubic-bezier(0.16, 1, 0.3, 1) 80ms forwards;
}

.gate-lede {
  font-size: 1rem;
  line-height: 1.6;
  color: color-mix(in srgb, var(--ink) 75%, transparent);
  max-width: 30rem;
  margin: 0 0 2.5rem;
  opacity: 0;
  animation: rise 600ms cubic-bezier(0.16, 1, 0.3, 1) 160ms forwards;
}

.gate-rule {
  height: 1px;
  background: var(--rule);
  margin: 0 0 2.5rem;
  transform-origin: left center;
  animation: rule-draw 640ms cubic-bezier(0.16, 1, 0.3, 1) 220ms both;
}

/* ── The entry button ────────────────────────────────────────── */
.enter {
  position: relative;
  display: grid;
  grid-template-columns: 1fr auto;
  grid-template-rows: auto auto;
  align-items: center;
  gap: 0.25rem 1rem;
  padding: 1.125rem 1.5rem;
  background: var(--ink);
  color: var(--paper);
  text-decoration: none;
  border-radius: 2px;
  font-family: var(--font-sans);
  transition: transform 220ms cubic-bezier(0.16, 1, 0.3, 1),
              background 220ms ease,
              color 220ms ease;
  opacity: 0;
  animation: rise 600ms cubic-bezier(0.16, 1, 0.3, 1) 320ms forwards;
}
.enter:hover {
  background: var(--accent);
  transform: translateY(-1px);
}
.enter:active { transform: translateY(0); }

.enter-label {
  grid-column: 1; grid-row: 1;
  font-size: 1rem;
  font-weight: 500;
  letter-spacing: 0.005em;
}
.enter-arrow {
  grid-column: 2; grid-row: 1 / span 2;
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 300;
  transition: transform 220ms cubic-bezier(0.16, 1, 0.3, 1);
}
.enter:hover .enter-arrow { transform: translateX(4px); }
.enter-meta {
  grid-column: 1; grid-row: 2;
  font-family: var(--font-mono);
  font-size: 0.625rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: color-mix(in srgb, var(--paper) 65%, transparent);
}

/* ── Annotation block ────────────────────────────────────────── */
.gate-note {
  display: grid;
  grid-template-columns: 5rem 1fr;
  gap: 1rem;
  margin: 2rem 0 0;
  padding-top: 1.5rem;
  border-top: 1px dashed var(--rule);
  font-size: 0.8125rem;
  line-height: 1.6;
  color: color-mix(in srgb, var(--ink) 70%, transparent);
  opacity: 0;
  animation: rise 600ms cubic-bezier(0.16, 1, 0.3, 1) 420ms forwards;
}
.note-key {
  font-family: var(--font-mono);
  font-size: 0.625rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: color-mix(in srgb, var(--ink) 50%, transparent);
  padding-top: 0.125rem;
}
.note-val code {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  background: color-mix(in srgb, var(--rule) 50%, transparent);
  padding: 1px 5px;
  border-radius: 2px;
}
.note-val a {
  color: var(--accent);
  text-decoration: underline;
  text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
  text-underline-offset: 2px;
}

/* ── Footer ──────────────────────────────────────────────────── */
.gate-foot {
  display: flex; flex-wrap: wrap;
  gap: 0.5rem;
  margin-top: 3rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--rule);
  font-family: var(--font-mono);
  font-size: 0.6875rem;
  letter-spacing: 0.04em;
  color: color-mix(in srgb, var(--ink) 55%, transparent);
  opacity: 0;
  animation: rise 600ms cubic-bezier(0.16, 1, 0.3, 1) 520ms forwards;
}
.gate-foot a {
  color: var(--accent);
  text-decoration: underline;
  text-decoration-color: color-mix(in srgb, var(--accent) 40%, transparent);
  text-underline-offset: 2px;
}

/* ── Keyframes ───────────────────────────────────────────────── */
@keyframes rise {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes rule-draw {
  from { transform: scaleX(0); }
  to   { transform: scaleX(1); }
}

@media (prefers-reduced-motion: reduce) {
  .enter, .gate-eyebrow, .gate-title, .gate-lede,
  .gate-note, .gate-foot, .specimen-rule, .gate-rule {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
}
</style>
