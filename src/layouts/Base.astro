---
import { ClientRouter } from 'astro:transitions'
import SITE from '../data/site-meta'
import { NAV_ITEMS, isLinkActive } from '../data/nav-config'
import InternalBanner from '../components/InternalBanner.astro'
import SiteFooter from '../components/SiteFooter.astro'
import ThemeToggle from '../components/ThemeToggle.vue'
import MobileNav from '../components/MobileNav.vue'
import NavDropdown from '../components/NavDropdown.vue'
import SearchBox from '../components/SearchBox.vue'
import '../styles/app.css'

const FONT_URL =
  'https://fonts.googleapis.com/css2?' +
  'family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600;9..144,700' +
  '&family=IBM+Plex+Sans:wght@300;400;500;600;700' +
  '&family=IBM+Plex+Mono:wght@400;500;600' +
  '&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700' +
  '&display=swap'

const { title, description } = Astro.props
const pageTitle = title ? `${title} | ${SITE.title}` : SITE.title
const path = Astro.url.pathname
---

<!DOCTYPE html>
<html lang={SITE.lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <ClientRouter />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href={FONT_URL} />
  <link rel="icon" type="image/png" href="/favicon-96x96.png?v=20260713" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=20260713" />
  <link rel="shortcut icon" href="/favicon.ico?v=20260713" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=20260713" />
  <link rel="manifest" href="/site.webmanifest?v=20260713" />
  <meta name="theme-color" content="#004996" />
  <meta name="color-scheme" content="light dark" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{pageTitle}</title>
  {description && <meta name="description" content={description} />}
  <script is:inline src="/blueprint.js" defer></script>
  <slot name="head" />
</head>
<body>
  <InternalBanner />
  <header class="site-nav sticky top-0 z-[100] bg-paper-soft dark:bg-paper-deep border-b border-rule">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-14">
      <a href="/" class="nav-brand flex items-center gap-2 no-underline text-ink min-w-0">
        <img src="/smart-logo-light.svg" alt="" class="logo-light h-7 w-auto shrink-0" />
        <img src="/smart-logo-dark.svg" alt="" class="logo-dark h-7 w-auto shrink-0" />
        <span class="font-serif text-base font-semibold tracking-tight truncate">OIML SMART</span>
      </a>
      <MobileNav client:load />
      <nav class="nav-menu hidden md:flex items-center gap-5" id="nav-menu">
        {NAV_ITEMS.map(item => (
          item.type === 'dropdown' ? (
            <NavDropdown client:load config={item.config} currentPath={path} />
          ) : (
            <a
              href={item.href}
              class={`text-sm font-medium text-ink-soft hover:text-accent transition-colors whitespace-nowrap ${isLinkActive(item.matchPrefix, path) ? 'text-accent font-semibold' : ''}`}
            >{item.label}</a>
          )
        ))}
        <SearchBox client:idle />
        <ThemeToggle client:load />
        <a href="/login/" class="text-sm font-semibold text-accent whitespace-nowrap">Sign in ↗</a>
      </nav>
    </div>
  </header>
  <main class="min-h-[calc(100vh-3.5rem-5rem)]">
    <slot />
  </main>
  <SiteFooter />

  <script is:inline>
    // ── FOUC prevention: set dark class before any JS loads ──
    var stored = localStorage.getItem('oiml-theme')
    var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
    if (stored === 'dark' || (!stored && prefersDark)) {
      document.documentElement.classList.add('dark')
    }

    // ── Astro View Transitions: carry dark class to new page ──
    document.addEventListener('astro:before-swap', function(e) {
      if (document.documentElement.classList.contains('dark')) {
        e.newDocument.documentElement.classList.add('dark')
      }
    })
  </script>
</body>
</html>

<style is:global>
.logo-dark { display: none; }
.dark .logo-light { display: none; }
.dark .logo-dark { display: inline-block; }
.cs-logo-dark { display: none; }
.dark .cs-logo-light { display: none; }
.dark .cs-logo-dark { display: inline-block; }
</style>