---
import { ClientRouter } from 'astro:transitions'
import SITE from '../data/site-meta'
import InternalBanner from '../components/InternalBanner.astro'
import ThemeToggle from '../components/ThemeToggle.vue'
import MobileNav from '../components/MobileNav.vue'
import AboutDropdown from '../components/AboutDropdown.vue'
import InternalToolsDropdown from '../components/InternalToolsDropdown.vue'
import SearchBox from '../components/SearchBox.vue'
import '../styles/app.css'

const FONT_URL =
  'https://fonts.googleapis.com/css2?' +
  'family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600;9..144,700' +
  '&family=IBM+Plex+Sans:wght@300;400;500;600;700' +
  '&family=IBM+Plex+Mono:wght@400;500;600' +
  '&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700' +
  '&display=swap'

const { title, description } = Astro.props
const pageTitle = title ? `${title} | ${SITE.title}` : SITE.title
const path = Astro.url.pathname
---

<!DOCTYPE html>
<html lang={SITE.lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <ClientRouter />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href={FONT_URL} />
  <link rel="icon" type="image/svg+xml" href="/smart-logo-light.svg" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#004996" />
  <meta name="color-scheme" content="light dark" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{pageTitle}</title>
  {description && <meta name="description" content={description} />}
  <slot name="head" />
</head>
<body>
  <InternalBanner />
  <header class="site-nav sticky top-0 z-[100] bg-paper-soft dark:bg-paper-deep border-b border-rule backdrop-saturate-[1.8] backdrop-blur-xl">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-14">
      <a href="/" class="nav-brand flex items-center gap-2 no-underline text-ink">
        <img src="/smart-logo-light.svg" alt="" class="logo-light h-7 w-auto" />
        <img src="/smart-logo-dark.svg" alt="" class="logo-dark h-7 w-auto" />
        <span class="font-serif text-base font-semibold tracking-tight">OIML SMART</span>
      </a>
      <MobileNav client:load />
      <nav class="nav-menu flex items-center gap-5" id="nav-menu">
        <a href="/recommendations/" class={`text-sm font-medium text-ink-soft hover:text-accent transition-colors whitespace-nowrap ${path.startsWith('/recommendations') ? 'text-accent font-semibold' : ''}`}>Recommendations</a>
        <a href="/library/" class={`text-sm font-medium text-ink-soft hover:text-accent transition-colors whitespace-nowrap ${path.startsWith('/library') ? 'text-accent font-semibold' : ''}`}>Documents</a>
        <a href="/vocab/" class={`text-sm font-medium text-ink-soft hover:text-accent transition-colors whitespace-nowrap ${path.startsWith('/vocab') ? 'text-accent font-semibold' : ''}`}>Vocabularies</a>
        <a href="/docs/" class={`text-sm font-medium text-ink-soft hover:text-accent transition-colors whitespace-nowrap ${path.startsWith('/docs') ? 'text-accent font-semibold' : ''}`}>Developers</a>
        <a href="/oiml-cs" class={`text-sm font-medium text-ink-soft hover:text-accent transition-colors whitespace-nowrap ${path === '/oiml-cs' ? 'text-accent font-semibold' : ''}`}>OIML-CS</a>
        <AboutDropdown client:load />
        <a href="/blog/" class={`text-sm font-medium text-ink-soft hover:text-accent transition-colors whitespace-nowrap ${path.startsWith('/blog') ? 'text-accent font-semibold' : ''}`}>Blog</a>
        <InternalToolsDropdown client:load />
        <SearchBox client:idle />
        <ThemeToggle client:load />
        <a href="/login/" class="text-sm font-semibold text-accent whitespace-nowrap">Sign in ↗</a>
      </nav>
    </div>
  </header>
  <main class="min-h-[calc(100vh-3.5rem-5rem)]">
    <slot />
  </main>
  <footer class="site-footer border-t border-rule bg-paper-raised py-8 px-6">
    <div class="max-w-7xl mx-auto text-center">
      <p class="text-[0.8125rem] text-ink-muted">A programme of the <a href="https://www.oiml.org" class="text-accent">International Organization of Legal Metrology</a>, delivered by <a href="https://www.ribose.com" class="text-accent">Ribose</a></p>
      <p class="copyright text-[0.8125rem] text-ink-muted mt-1">Content © OIML · Code © Ribose</p>
    </div>
  </footer>

  <script is:inline>
    // ── FOUC prevention: set dark class before any JS loads ──
    var stored = localStorage.getItem('oiml-theme')
    var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
    if (stored === 'dark' || (!stored && prefersDark)) {
      document.documentElement.classList.add('dark')
    }

    // ── Astro View Transitions: carry dark class to new page ──
    document.addEventListener('astro:before-swap', function(e) {
      if (document.documentElement.classList.contains('dark')) {
        e.newDocument.documentElement.classList.add('dark')
      }
    })
  </script>
</body>
</html>

<style is:global>
/* Dark-mode logo switching (light logo by default, dark logo when .dark) */
.logo-dark { display: none; }
.dark .logo-light { display: none; }
.dark .logo-dark { display: inline-block; }

/* Mobile nav: slide-in panel toggled by body.nav-open (set by MobileNav.vue) */
@media (max-width: 768px) {
  .nav-menu {
    position: fixed; top: 3.5rem; left: 0; right: 0; bottom: 0;
    background: var(--paper); flex-direction: column; padding: 2rem 1.5rem;
    gap: 1.25rem; transform: translateX(100%); transition: transform 0.25s ease;
    z-index: 90; overflow-y: auto;
  }
  .nav-open .nav-menu { transform: translateX(0); }
}
</style>