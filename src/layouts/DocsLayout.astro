---
import Base from './Base.astro'
import DocsSidebar from '../components/DocsSidebar.astro'

const { title, description } = Astro.props
---

<Base title={title} description={description}>
  <div class="grid grid-cols-[220px_minmax(0,1fr)] gap-12 max-w-[76rem] mx-auto px-6 max-[960px]:grid-cols-1 max-[960px]:gap-0">
    <aside class="sticky top-16 max-h-[calc(100vh-4rem)] overflow-y-auto self-start pt-6 border-r border-rule max-[960px]:hidden">
      <DocsSidebar />
    </aside>
    <div class="min-w-0 pt-6 pb-16">
      <slot />
    </div>
  </div>
</Base>
