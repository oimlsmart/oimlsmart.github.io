---
import Base from './Base.astro'
import PageHero from '../components/PageHero.astro'
import DraftCallout from '../components/DraftCallout.astro'
import { render } from 'astro:content'

const { entry } = Astro.props
const { Content } = await render(entry)
const { title, description, eyebrow } = entry.data
---

<Base title={title} description={description}>
  <article class="prose">
    <PageHero eyebrow={eyebrow} title={title} lede={description} />
    <DraftCallout />
    <Content />
  </article>
</Base>

<style>
.prose {
  max-width: 48rem;
  margin: 0 auto;
  padding: 2rem 1.5rem;
}

/* :global() targets markdown content rendered by <Content /> */
.prose :global(h1) {
  font-family: var(--vp-font-family-serif);
  font-size: 2.5rem; font-weight: 600; line-height: 1.1;
  letter-spacing: -0.025em; margin-bottom: 1.5rem; color: var(--ink);
}
.prose :global(h2) {
  font-family: var(--vp-font-family-serif);
  font-size: 1.75rem; font-weight: 500; line-height: 1.2;
  margin-top: 3rem; margin-bottom: 1rem; padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--rule); color: var(--ink);
}
.prose :global(h3) {
  font-family: var(--vp-font-family-serif);
  font-size: 1.25rem; font-weight: 600;
  margin-top: 2rem; margin-bottom: 0.75rem;
}
.prose :global(p) {
  font-family: var(--vp-font-family-base);
  line-height: 1.7; margin-bottom: 1rem;
}
.prose :global(ul),
.prose :global(ol) {
  margin-bottom: 1rem; padding-left: 1.5rem;
}
.prose :global(ul) { list-style: disc; }
.prose :global(ol) { list-style: decimal; }
.prose :global(li) { line-height: 1.7; margin-bottom: 0.5rem; }
.prose :global(a) {
  color: var(--accent); text-decoration: underline;
  text-underline-offset: 3px; text-decoration-thickness: 1px;
}
.prose :global(a:hover) { text-decoration-color: var(--accent); }
.prose :global(code) {
  font-family: var(--vp-font-family-mono); font-size: 0.875em;
  background: var(--accent-soft); padding: 0.125em 0.375em;
  border-radius: 3px; font-weight: 500;
}
.prose :global(pre) {
  background: var(--paper-raised); border: 1px solid var(--rule);
  border-radius: 6px; padding: 1rem; overflow-x: auto; margin-bottom: 1.5rem;
}
.prose :global(pre code) {
  background: transparent; padding: 0; font-weight: 400; font-size: 0.875rem;
}
.prose :global(blockquote) {
  border-left: 3px solid var(--accent); padding-left: 1rem;
  margin: 1.5rem 0; color: var(--ink-soft); font-style: italic;
}
.prose :global(table) {
  width: 100%; border-collapse: collapse; margin: 1.5rem 0;
}
.prose :global(th),
.prose :global(td) {
  padding: 0.75rem; border: 1px solid var(--rule); text-align: left;
}
.prose :global(th) { background: var(--paper-raised); font-weight: 600; }
.prose :global(img) { max-width: 100%; height: auto; margin: 1.5rem 0; }

/* Steps list */
.prose :global(.steps) { counter-reset: step; list-style: none; padding: 0; margin: 1.5rem 0; }
.prose :global(.steps li) {
  counter-increment: step; display: grid; grid-template-columns: 3rem 1fr;
  gap: 1rem; margin-bottom: 1.25rem; align-items: start;
}
.prose :global(.steps li::before) {
  content: counter(step, decimal-leading-zero);
  font-family: var(--vp-font-family-mono); font-size: 0.875rem; font-weight: 500;
  color: var(--accent); border-top: 1px solid var(--accent); padding-top: 0.125rem;
}

/* Swatch + logo grids (branding page) */
.prose :global(.swatch-grid) {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 0.75rem; margin: 1.5rem 0;
}
.prose :global(.swatch-grid .swatch) {
  border-radius: 4px; overflow: hidden; border: 1px solid var(--rule);
  background: var(--paper-soft);
}
.prose :global(.swatch-grid .swatch .chip) { height: 4.5rem; border-bottom: 1px solid var(--rule); }
.prose :global(.swatch-grid .swatch .meta) { padding: 0.625rem 0.75rem; }
.prose :global(.swatch-grid .swatch .meta .name) { font-size: 0.8125rem; font-weight: 600; }
.prose :global(.swatch-grid .swatch .meta .hex) {
  display: block; font-family: var(--vp-font-family-mono);
  font-size: 0.6875rem; color: var(--ink-muted); margin-top: 0.125rem;
}
.prose :global(.logo-grid) {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 1rem; margin: 1.5rem 0;
}
.prose :global(.logo-grid .card) {
  background: var(--paper-soft); border: 1px solid var(--rule);
  border-radius: 6px; padding: 1.75rem; text-align: center;
  display: flex; flex-direction: column; align-items: center; gap: 1rem;
}
.prose :global(.logo-grid .card .preview) { height: 80px; display: flex; align-items: center; justify-content: center; }
.prose :global(.logo-grid .card .preview.dark-bg) { background: var(--paper-deep); border-radius: 4px; width: 100%; }
.prose :global(.logo-grid .card .preview img) { max-height: 64px; max-width: 80%; }
.prose :global(.logo-grid .card .label) {
  font-family: var(--vp-font-family-mono); font-size: 0.75rem; font-weight: 500;
  letter-spacing: 0.08em; text-transform: uppercase; color: var(--ink-muted);
}
.prose :global(.logo-grid .card .download) {
  font-size: 0.8125rem; color: var(--accent); font-weight: 500;
}

/* Recommendation cards (recommendations index) */
.prose :global(.rec-grid) {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 2rem 0;
}
@media (max-width: 768px) { .prose :global(.rec-grid) { grid-template-columns: 1fr; } }
.prose :global(.rec-card) {
  display: block; padding: 1.75rem; background: var(--paper-soft);
  border: 1px solid var(--rule); border-radius: 6px; text-decoration: none;
  color: inherit; transition: all 0.2s ease;
}
.prose :global(.rec-card:hover) { border-color: var(--accent); transform: translateY(-2px); }
</style>