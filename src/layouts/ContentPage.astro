---
import Base from './Base.astro'
import PageHero from '../components/PageHero.astro'
import { render, type CollectionEntry, type ComponentRenderer } from 'astro:content'

interface Props {
  entry?: CollectionEntry<'pages'>
  title?: string
  description?: string
  eyebrow?: string
  lede?: string
}

const props = Astro.props
let Content: ComponentRenderer | null = null
let title: string | undefined
let description: string | undefined
let eyebrow: string | undefined

if (props.entry) {
  const rendered = await render(props.entry)
  Content = rendered.Content
  title = props.entry.data.title
  description = props.entry.data.description
  eyebrow = props.entry.data.eyebrow
} else {
  title = props.title
  description = props.description
  eyebrow = props.eyebrow
}

const displayLede = props.lede ?? description
---

<Base title={title} description={description}>
  <div class="relative bp-noise">
    {title && <PageHero title={title} lede={displayLede} eyebrow={eyebrow} />}
    <article class="prose prose-enhanced bp-reveal" style="--reveal-delay: 200ms;">
      {Content ? <Content /> : <slot />}
    </article>
    <div class="bp-ticks bp-ticks--dense" aria-hidden="true"></div>
  </div>
</Base>

<style is:global>
  .prose-enhanced {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }
  .prose-enhanced h2 {
    position: relative;
    padding-top: 2rem;
    margin-top: 4rem;
  }
  .prose-enhanced h2::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 32px;
    height: 2px;
    background: var(--accent);
  }
  .prose-enhanced h3 {
    scroll-margin-top: 5rem;
  }
</style>
