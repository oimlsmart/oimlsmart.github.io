---
import DocsLayout from './DocsLayout.astro'
import PageHero from '../components/PageHero.astro'
import DraftCallout from '../components/DraftCallout.astro'
import { getCollection, render } from 'astro:content'

const { entry } = Astro.props
const { Content } = await render(entry)
const { title, description } = entry.data

const all = (await getCollection('docs')).sort((a, b) => a.id.localeCompare(b.id))
const idx = all.findIndex(d => d.id === entry.id)
const prev = idx > 0 ? all[idx - 1] : null
const next = idx < all.length - 1 ? all[idx + 1] : null
---

<DocsLayout title={title} description={description}>
  <PageHero title={title} lede={description} />
  <DraftCallout />
  <div class="docs-body">
    <Content />
  </div>
  {(prev || next) && (
    <nav class="pn">
      {prev && (
        <a class="pn-link" href={`/docs/${prev.id}`}>
          <span class="pn-dir">← Previous</span>
          <span class="pn-name">{prev.data.shortTitle || prev.data.title}</span>
        </a>
      )}
      {next && (
        <a class="pn-link pn-right" href={`/docs/${next.id}`}>
          <span class="pn-dir">Next →</span>
          <span class="pn-name">{next.data.shortTitle || next.data.title}</span>
        </a>
      )}
    </nav>
  )}
</DocsLayout>

<style is:global>
.docs-body h2 {
  font-family: var(--vp-font-family-serif);
  font-size: 1.5rem; font-weight: 600;
  margin-top: 2.5rem; margin-bottom: 0.75rem;
}
.docs-body h3 {
  font-family: var(--vp-font-family-serif);
  font-size: 1.1875rem; font-weight: 600;
  margin-top: 1.75rem; margin-bottom: 0.5rem;
}
.docs-body p { line-height: 1.7; margin-bottom: 1rem; }
.docs-body ul, .docs-body ol { padding-left: 1.5rem; margin-bottom: 1rem; }
.docs-body ul { list-style: disc; }
.docs-body ol { list-style: decimal; }
.docs-body li { line-height: 1.7; margin-bottom: 0.375rem; }
.docs-body a { color: var(--accent); text-decoration: underline; text-underline-offset: 2px; }
.docs-body code {
  font-family: var(--vp-font-family-mono); font-size: 0.85em;
  background: var(--accent-soft); padding: 0.1em 0.3em; border-radius: 3px;
}
.docs-body pre {
  background: var(--paper-raised); border: 1px solid var(--rule);
  border-radius: 6px; padding: 1rem; overflow-x: auto; margin-bottom: 1.25rem;
}
.docs-body pre code { background: transparent; padding: 0; font-size: 0.8125rem; }
.docs-body table { width: 100%; border-collapse: collapse; margin: 1.25rem 0; }
.docs-body th, .docs-body td { padding: 0.5rem 0.75rem; border: 1px solid var(--rule); text-align: left; font-size: 0.875rem; }
.docs-body th { background: var(--paper-raised); font-weight: 600; }
.docs-body blockquote {
  border-left: 3px solid var(--accent); padding-left: 1rem;
  margin: 1.25rem 0; color: var(--ink-soft); font-style: italic;
}
</style>

<style>
.pn {
  display: flex; justify-content: space-between; gap: 1rem;
  margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--rule);
}
.pn-link {
  display: flex; flex-direction: column; gap: 0.125rem;
  text-decoration: none; padding: 0.875rem 1rem;
  border: 1px solid var(--rule); border-radius: 6px;
  flex: 1; transition: border-color 0.15s;
}
.pn-link:hover { border-color: var(--accent); }
.pn-right { text-align: right; }
.pn-dir {
  font-family: var(--vp-font-family-mono);
  font-size: 0.6875rem; color: var(--ink-muted);
}
.pn-name { font-weight: 500; color: var(--ink); font-size: 0.875rem; }
</style>