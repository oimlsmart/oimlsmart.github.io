---
import DocsLayout from './DocsLayout.astro'
import PageHero from '../components/PageHero.astro'
import DraftCallout from '../components/DraftCallout.astro'
import { getCollection, render } from 'astro:content'

const { entry } = Astro.props
const { Content } = await render(entry)
const { title, description } = entry.data

const all = (await getCollection('docs')).sort((a, b) => a.id.localeCompare(b.id))
const idx = all.findIndex(d => d.id === entry.id)
const prev = idx > 0 ? all[idx - 1] : null
const next = idx < all.length - 1 ? all[idx + 1] : null
---

<DocsLayout title={title} description={description}>
  <PageHero title={title} lede={description} />
  <DraftCallout />
  <div class="docs-body">
    <Content />
  </div>
  {(prev || next) && (
    <nav class="flex justify-between gap-4 mt-12 pt-8 border-t border-rule">
      {prev && (
        <a class="flex flex-col gap-0.5 no-underline py-3.5 px-4 border border-rule rounded-md flex-1 transition-colors hover:border-accent" href={`/docs/${prev.id}`}>
          <span class="font-mono text-[0.6875rem] text-ink-muted">← Previous</span>
          <span class="font-medium text-ink text-sm">{prev.data.shortTitle || prev.data.title}</span>
        </a>
      )}
      {next && (
        <a class="flex flex-col gap-0.5 no-underline py-3.5 px-4 border border-rule rounded-md flex-1 text-right transition-colors hover:border-accent" href={`/docs/${next.id}`}>
          <span class="font-mono text-[0.6875rem] text-ink-muted">Next →</span>
          <span class="font-medium text-ink text-sm">{next.data.shortTitle || next.data.title}</span>
        </a>
      )}
    </nav>
  )}
</DocsLayout>
