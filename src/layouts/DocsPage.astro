---
import Base from './Base.astro'
import PageHero from '../components/PageHero.astro'
import DraftCallout from '../components/DraftCallout.astro'
import DocsSidebar from '../components/DocsSidebar.astro'

const { entry } = Astro.props
import { render } from "astro:content"
const { Content } = await render(entry)
const { title, description, eyebrow } = entry.data
---

<Base title={title} description={description}>
  <div class="docs-layout">
    <DocsSidebar />
    <article class="docs-content">
      <PageHero eyebrow={eyebrow} title={title} lede={description} />
      <DraftCallout />
      <div class="prose-body">
        <Content />
      </div>
    </article>
  </div>
</Base>

<style>
.docs-layout { display: flex; max-width: 80rem; margin: 0 auto; padding: 0 1.5rem; gap: 2rem; }
.docs-content { flex: 1; min-width: 0; padding: 2rem 0; max-width: 48rem; }
.prose-body :global(h2) {
  font-family: var(--vp-font-family-serif); font-size: 1.75rem;
  font-weight: 500; margin-top: 3rem; padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--vp-c-divider);
}
.prose-body :global(h3) {
  font-family: var(--vp-font-family-serif); font-size: 1.25rem; margin-top: 2rem;
}
.prose-body :global(p), .prose-body :global(li) { line-height: 1.7; }
.prose-body :global(pre) {
  background: var(--vp-c-bg-soft); border-radius: 6px; padding: 1rem;
  overflow-x: auto; font-family: var(--vp-font-family-mono); font-size: 0.875rem;
}
.prose-body :global(code) {
  font-family: var(--vp-font-family-mono); font-size: 0.875em;
  background: var(--vp-c-brand-soft); padding: 0.125em 0.375em; border-radius: 3px;
}
</style>