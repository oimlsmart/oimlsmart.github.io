---
import Base from './Base.astro'
import PageHero from '../components/PageHero.astro'

export async function getStaticPaths() {
  const posts = (await import('../content/config')).collections
  // Blog posts are under src/content/blog/
  const allPosts = import.meta.glob('./blog/*.mdx', { eager: true })
  return Object.entries(allPosts).map(([path, post]) => ({
    params: { slug: path.replace('./blog/', '').replace('.mdx', '') },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content, frontmatter } = post
---

<Base title={frontmatter.title} description={frontmatter.summary}>
  <article class="prose">
    <PageHero eyebrow="Blog" title={frontmatter.title} lede={frontmatter.summary} />
    <Content />
  </article>
</Base>