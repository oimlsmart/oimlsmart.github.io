---
// ── OntologyLayout.astro ─────────────────────────────────────────────
// Two-pane layout for /ontology/* routes. The sidebar is an always-visible
// flat list of every entity — no collapsing, no expanding. Search filters
// live; type chips narrow by category; section headers group by ontology
// without hiding anything.

import Base from './Base.astro'
import { ontologyEntities, ontologyNamespaces, ontologyTypeMeta } from '../data/ontology-data'

interface Entity {
  uri: string
  qname: string
  slug: string
  label: string
  description: string
  ontology: string
  type: string
}

interface NamespaceEntry {
  prefix: string
  title: string
  color: string
  version: string
  uri: string
  description: string
}

interface Props {
  title: string
  description?: string
  activeSlug?: string
}

const { title, description, activeSlug = '' } = Astro.props

const all = ontologyEntities as readonly Entity[]
const namespaces = ontologyNamespaces as readonly NamespaceEntry[]
const typeMeta = ontologyTypeMeta as Record<string, { label: string; color: string; colorDot: string }>
const knownPrefixes = new Set(namespaces.map((n) => n.prefix))
const visible = all.filter((e) => knownPrefixes.has(e.ontology))

const nsOrder = ['smart', 'oiml', 'oiml-pubtype']
const orderedNamespaces = nsOrder
  .map((p) => namespaces.find((n) => n.prefix === p))
  .filter((n): n is NamespaceEntry => Boolean(n))

const entitiesByOntology = new Map<string, Entity[]>()
for (const ns of orderedNamespaces) {
  entitiesByOntology.set(
    ns.prefix,
    visible
      .filter((e) => e.ontology === ns.prefix)
      .slice()
      .sort((a, b) => {
        // Sort by type (class first, then properties, etc.) then by label
        const typeOrder = ['ontology', 'class', 'objectProperty', 'datatypeProperty', 'annotationProperty', 'conceptScheme', 'concept', 'individual']
        const ta = typeOrder.indexOf(a.type)
        const tb = typeOrder.indexOf(b.type)
        if (ta !== tb) return (ta === -1 ? 99 : ta) - (tb === -1 ? 99 : tb)
        return a.label.localeCompare(b.label)
      })
  )
}

const typeCounts: Record<string, number> = {}
for (const e of visible) typeCounts[e.type] = (typeCounts[e.type] || 0) + 1
const typeOptions = Object.entries(typeMeta)
  .filter(([t]) => typeCounts[t])
  .map(([t, m]) => ({ type: t, label: m.label, count: typeCounts[t] }))
  .sort((a, b) => a.label.localeCompare(b.label))

const nsColor: Record<string, string> = {
  smart: 'bg-teal-500',
  oiml: 'bg-brand-500',
  'oiml-pubtype': 'bg-amber-500',
  external: 'bg-slate-400',
}

const nsAccent: Record<string, string> = {
  smart: 'text-teal-700 dark:text-teal-300',
  oiml: 'text-brand-700 dark:text-brand-300',
  'oiml-pubtype': 'text-amber-700 dark:text-amber-300',
}
---

<Base title={title} description={description}>
  <div class="ontology-layout max-w-[100rem] mx-auto px-4 sm:px-6 lg:px-8 bp-grid">
    <!-- Mobile toggle (hidden on lg+) -->
    <button
      id="ontology-sidebar-toggle"
      class="ontology-sidebar-toggle lg:hidden mb-3 inline-flex items-center gap-2 px-3 py-2 border border-rule rounded bg-paper-soft text-sm font-medium text-ink hover:bg-paper-raised bp-focus-ring"
      aria-expanded="false"
      aria-controls="ontology-sidebar"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18" /></svg>
      <span>Ontology browser</span>
      <svg class="w-3 h-3 ml-auto transition-transform" data-chevron viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6" /></svg>
    </button>

    <div class="ontology-layout__grid grid gap-6 lg:grid-cols-[22rem_minmax(0,1fr)]">

      <!-- ═══ SIDEBAR ═══ -->
      <aside
        id="ontology-sidebar"
        class="ontology-sidebar lg:sticky lg:top-[5.5rem] lg:max-h-[calc(100vh-7rem)] flex flex-col bp-crosshair bg-paper-soft border border-rule rounded-md overflow-hidden"
        data-open="false"
      >
        <!-- Search header -->
        <header class="px-4 py-3 border-b border-rule bg-paper-raised">
          <div class="flex items-center justify-between mb-2">
            <span class="bp-coord">§ Ontology</span>
            <span class="bp-tally">
              <span class="bp-tally__current" id="ontology-sidebar-visible-count">{visible.length}</span>
              <span class="bp-tally__sep">/</span>
              <span>{visible.length}</span>
            </span>
          </div>
          <div class="relative">
            <input
              type="search"
              id="ontology-sidebar-search"
              placeholder="Search entities…   ( / )"
              class="w-full pl-8 pr-7 py-1.5 text-xs border border-rule rounded bg-paper text-ink focus:outline-none focus:border-accent bp-focus-ring"
              autocomplete="off"
              aria-label="Search ontology entities"
            />
            <svg class="absolute left-2 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-ink-muted pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" />
            </svg>
            <kbd id="ontology-sidebar-kbd" class="absolute right-2 top-1/2 -translate-y-1/2 text-[9px] font-mono px-1 py-0.5 border border-rule rounded bg-paper text-ink-muted pointer-events-none">/</kbd>
          </div>
          <!-- Type chips -->
          <div class="flex flex-wrap gap-1 mt-2" id="ontology-sidebar-types">
            <button data-filter-type="" class="is-active text-[10px] px-1.5 py-0.5 rounded border bg-accent text-white border-accent">All <span class="opacity-70">{visible.length}</span></button>
            {typeOptions.map((t) => (
              <button data-filter-type={t.type} class="text-[10px] px-1.5 py-0.5 rounded border bg-paper text-ink-soft border-rule hover:border-ink">
                {t.label} <span class="opacity-60">{t.count}</span>
              </button>
            ))}
          </div>
        </header>

        <!-- Flat list of all entities, grouped by ontology (no collapsing) -->
        <nav class="ontology-sidebar__list flex-1 overflow-y-auto" id="ontology-sidebar-list" aria-label="Ontology entities">
          {orderedNamespaces.map((ns) => {
            const entities = entitiesByOntology.get(ns.prefix) || []
            return (
              <details
                open
                data-ontology={ns.prefix}
                class="ontology-sidebar__family border-b border-rule last:border-0 group"
              >
                <summary class="sticky top-0 z-10 flex items-center gap-2 px-3 py-2 bg-paper-raised border-b border-rule cursor-pointer hover:bg-paper list-none bp-focus-ring">
                  <span class={`w-2 h-2 rounded-full ${nsColor[ns.prefix]}`}></span>
                  <span class={`font-mono text-[10px] uppercase tracking-[0.1em] ${nsAccent[ns.prefix]}`}>{ns.prefix}</span>
                  <span class="text-xs text-ink-muted truncate flex-1">{ns.title.replace('Ontology', '').replace('Taxonomy', '').trim()}</span>
                  <span class="bp-coord">{entities.length}</span>
                  <svg class="w-3 h-3 text-ink-muted transition-transform group-open:rotate-0 -rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6" /></svg>
                </summary>
                <ul class="py-1">
                  {entities.map((e) => {
                    const isActive = e.slug === activeSlug
                    return (
                      <li
                        class="ontology-sidebar__entity"
                        data-qname={e.qname}
                        data-label={e.label.toLowerCase()}
                        data-type={e.type}
                        data-ontology={e.ontology}
                        data-description={(e.description || '').toLowerCase()}
                      >
                        <a
                          href={`/ontology/${e.slug}`}
                          class={`flex items-start gap-2 py-1 px-3 border-l-2 transition-colors no-underline text-inherit ${
                            isActive
                              ? 'bg-accent-soft border-accent'
                              : 'border-transparent hover:bg-paper-raised'
                          }`}
                          data-active={isActive ? 'true' : 'false'}
                          title={`${typeMeta[e.type]?.label || e.type} — ${e.qname}`}
                        >
                          <span class={`w-1 h-1 mt-1.5 rounded-full shrink-0 ${nsColor[e.ontology] || 'bg-slate-400'}`}></span>
                          <span class="flex-1 min-w-0">
                            <span class={`block text-[11px] font-mono truncate ${isActive ? 'text-accent font-semibold' : 'text-ink'}`}>{e.qname.split(':').slice(1).join(':')}</span>
                            <span class="block text-[9px] text-ink-muted truncate">{e.label} · {typeMeta[e.type]?.label || e.type}</span>
                          </span>
                        </a>
                      </li>
                    )
                  })}
                </ul>
              </details>
            )
          })}
          <p class="ontology-sidebar__empty text-[10px] text-ink-muted italic px-3 py-4 text-center hidden">No matches.</p>
        </nav>

        <!-- Footer -->
        <footer class="px-3 py-2 border-t border-rule bg-paper-raised flex items-center justify-between">
          <span class="bp-coord">{orderedNamespaces.length} ontologies</span>
          <a href="/ontology/" class="text-[10px] text-accent hover:underline">Overview →</a>
        </footer>
      </aside>

      <!-- ═══ MAIN ═══ -->
      <main class="ontology-main min-w-0">
        <slot />
      </main>
    </div>
  </div>

  <script is:inline>
    (function () {
      if (window.__ontologySidebarWired) {
        window.__ontologySidebarBind && window.__ontologySidebarBind();
        return;
      }
      window.__ontologySidebarWired = true;

      function bind() {
        const input = document.getElementById('ontology-sidebar-search');
        const list = document.getElementById('ontology-sidebar-list');
        const kbd = document.getElementById('ontology-sidebar-kbd');
        const countEl = document.getElementById('ontology-sidebar-visible-count');
        const emptyEl = list && list.querySelector('.ontology-sidebar__empty');
        const sidebar = document.getElementById('ontology-sidebar');
        const toggle = document.getElementById('ontology-sidebar-toggle');
        const typeBtns = list ? list.parentElement.parentElement.querySelectorAll('#ontology-sidebar-types [data-filter-type]') : [];
        if (!input || !list) return;

        const items = Array.from(list.querySelectorAll('.ontology-sidebar__entity'));
        const sections = Array.from(list.querySelectorAll('[data-ontology]'));
        let currentType = '';

        function applyFilters() {
          const q = (input.value || '').toLowerCase().trim();
          let totalVisible = 0;
          for (const item of items) {
            const label = item.getAttribute('data-label') || '';
            const qname = (item.getAttribute('data-qname') || '').toLowerCase();
            const desc = item.getAttribute('data-description') || '';
            const type = item.getAttribute('data-type') || '';
            const matchesText = !q || label.includes(q) || qname.includes(q) || desc.includes(q);
            const matchesType = !currentType || type === currentType;
            const show = matchesText && matchesType;
            item.style.display = show ? '' : 'none';
            if (show) totalVisible++;
          }
          // Hide empty sections
          for (const sec of sections) {
            const visibleChildren = sec.querySelectorAll('.ontology-sidebar__entity:not([style*="display: none"])').length;
            sec.style.display = visibleChildren > 0 ? '' : 'none';
          }
          if (countEl) countEl.textContent = String(totalVisible);
          if (emptyEl) emptyEl.classList.toggle('hidden', totalVisible > 0);
        }

        input.addEventListener('input', applyFilters);
        if (kbd) {
          input.addEventListener('focus', () => kbd.classList.add('hidden'));
          input.addEventListener('blur', () => { if (!input.value) kbd.classList.remove('hidden'); });
        }

        // Type chips
        const typeContainer = document.getElementById('ontology-sidebar-types');
        if (typeContainer) {
          typeContainer.addEventListener('click', (e) => {
            const btn = e.target.closest('[data-filter-type]');
            if (!btn) return;
            currentType = btn.getAttribute('data-filter-type') || '';
            typeContainer.querySelectorAll('[data-filter-type]').forEach((b) => {
              b.classList.remove('is-active', 'bg-accent', 'text-white', 'border-accent');
              b.classList.add('bg-paper', 'text-ink-soft', 'border-rule');
            });
            btn.classList.add('is-active', 'bg-accent', 'text-white', 'border-accent');
            btn.classList.remove('bg-paper', 'text-ink-soft', 'border-rule');
            applyFilters();
          });
        }

        // Mobile drawer
        if (toggle && sidebar) {
          toggle.addEventListener('click', () => {
            const open = sidebar.getAttribute('data-open') === 'true';
            sidebar.setAttribute('data-open', open ? 'false' : 'true');
            toggle.setAttribute('aria-expanded', open ? 'false' : 'true');
            const chevron = toggle.querySelector('[data-chevron]');
            if (chevron) chevron.style.transform = open ? '' : 'rotate(180deg)';
          });
        }

        // Global "/" focus, ESC clear
        document.addEventListener('keydown', (e) => {
          if (e.key === '/' && document.activeElement !== input && !e.target.matches('input, textarea, select')) {
            e.preventDefault();
            input.focus();
          }
          if (e.key === 'Escape' && document.activeElement === input) {
            input.value = '';
            applyFilters();
            input.blur();
          }
        });

        // Sidebar should not move on click — don't scroll active into view.
        // (Previously: scrollIntoView on bind caused the sidebar to jump
        // after navigation. Removed per user direction.)
      }

      window.__ontologySidebarBind = bind;
      document.addEventListener('astro:page-load', bind);
      bind();
    })();
  </script>

  <style is:global>
    .ontology-layout { position: relative; padding-top: 1rem; padding-bottom: 2rem; }
    /* Native details/summary styling — kill the default marker */
    .ontology-sidebar__family > summary { list-style: none; }
    .ontology-sidebar__family > summary::-webkit-details-marker { display: none; }
    @media (max-width: 1023px) {
      .ontology-sidebar {
        max-height: 0;
        overflow: hidden;
        border: 0;
        padding: 0;
        margin: 0;
        transition: max-height 200ms ease-in-out;
      }
      .ontology-sidebar[data-open="true"] {
        max-height: 32rem;
        border: 1px solid var(--color-rule);
        margin-bottom: 1rem;
      }
    }
  </style>
</Base>
