---
// ── OntologyLayout.astro ─────────────────────────────────────────────
// Two-pane layout for /ontology/* routes. Sidebar is server-rendered
// as a hierarchy tree (classes nested under their parents; other types
// flat). Sticky on lg+ so it stays visible while scrolling.

import Base from './Base.astro'
import { ontologyEntities, ontologyNamespaces, ontologyTypeMeta } from '../data/ontology-data'

interface Entity {
  uri: string
  qname: string
  slug: string
  label: string
  description: string
  ontology: string
  type: string
  parent?: string
  domain?: string[]
  range?: string[]
  instanceOf?: string[]
}

interface NamespaceEntry {
  prefix: string
  title: string
  color: string
  version: string
  uri: string
  description: string
}

interface Props {
  title: string
  description?: string
  activeSlug?: string
}

const { title, description, activeSlug = '' } = Astro.props

const all = ontologyEntities as readonly Entity[]
const namespaces = ontologyNamespaces as readonly NamespaceEntry[]
const typeMeta = ontologyTypeMeta as Record<string, { label: string; color: string; colorDot: string }>
const knownPrefixes = new Set(namespaces.map((n) => n.prefix))
const visible = all.filter((e) => knownPrefixes.has(e.ontology))

const nsOrder = ['smart', 'oiml', 'oiml-pubtype']
const typeOrder = ['ontology', 'class', 'objectProperty', 'datatypeProperty', 'annotationProperty', 'conceptScheme', 'concept', 'individual']

// Group by ontology then by type, with classes nested as a parent→children tree.
interface SidebarGroup {
  ns: NamespaceEntry
  sections: Array<{
    type: string
    label: string
    tree: TreeNode[]   // classes nested; other types flat (depth=0)
    flatCount: number  // total entities in this section
  }>
  totalCount: number
}

interface TreeNode {
  entity: Entity
  depth: number
  children: TreeNode[]
}

function buildClassTree(entities: Entity[]): TreeNode[] {
  const byQname = new Map(entities.map((e) => [e.qname, e]))
  const childrenOf = new Map<string, Entity[]>()
  for (const e of entities) {
    if (!e.parent || !byQname.has(e.parent)) continue
    const arr = childrenOf.get(e.parent) || []
    arr.push(e)
    childrenOf.set(e.parent, arr)
  }
  // Roots = classes with no parent OR whose parent isn't in this set
  const roots = entities.filter((e) => !e.parent || !byQname.has(e.parent))
  const sortSiblings = (a: Entity, b: Entity) => a.label.localeCompare(b.label)

  function build(entity: Entity, depth: number, seen: Set<string>): TreeNode {
    if (seen.has(entity.qname)) return { entity, depth, children: [] }
    seen.add(entity.qname)
    const kids = (childrenOf.get(entity.qname) || []).slice().sort(sortSiblings)
    return {
      entity,
      depth,
      children: kids.map((k) => build(k, depth + 1, new Set(seen))),
    }
  }
  return roots.slice().sort(sortSiblings).map((r) => build(r, 0, new Set()))
}

function flattenTree(nodes: TreeNode[]): TreeNode[] {
  const out: TreeNode[] = []
  function walk(n: TreeNode) {
    out.push(n)
    n.children.forEach(walk)
  }
  nodes.forEach(walk)
  return out
}

const groups: SidebarGroup[] = nsOrder
  .filter((prefix) => namespaces.find((n) => n.prefix === prefix))
  .map((prefix) => {
    const ns = namespaces.find((n) => n.prefix === prefix)!
    const ontEntities = visible.filter((e) => e.ontology === prefix)
    const sections = typeOrder
      .filter((t) => ontEntities.some((e) => e.type === t))
      .map((t) => {
        const matching = ontEntities.filter((e) => e.type === t)
        const tree = t === 'class'
          ? buildClassTree(matching)
          : matching.slice().sort((a, b) => a.label.localeCompare(b.label)).map((e) => ({ entity: e, depth: 0, children: [] }))
        return {
          type: t,
          label: typeMeta[t]?.label || t,
          tree,
          flatCount: matching.length,
        }
      })
    return { ns, sections, totalCount: ontEntities.length }
  })

const nsColor: Record<string, string> = {
  smart: 'bg-teal-500',
  oiml: 'bg-brand-500',
  'oiml-pubtype': 'bg-amber-500',
  external: 'bg-slate-400',
}
---

<Base title={title} description={description}>
  <div class="ontology-layout max-w-[100rem] mx-auto px-4 sm:px-6 lg:px-8 bp-grid">
    <!-- Mobile toggle (hidden on lg+) -->
    <button
      id="ontology-sidebar-toggle"
      class="ontology-sidebar-toggle lg:hidden mb-3 inline-flex items-center gap-2 px-3 py-2 border border-rule rounded bg-paper-soft text-sm font-medium text-ink hover:bg-paper-raised bp-focus-ring"
      aria-expanded="false"
      aria-controls="ontology-sidebar"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18" /></svg>
      <span>Ontology browser</span>
      <svg class="w-3 h-3 ml-auto transition-transform" data-chevron viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6" /></svg>
    </button>

    <div class="ontology-layout__grid grid gap-6 lg:grid-cols-[20rem_minmax(0,1fr)]">

      <!-- ═══ SIDEBAR ═══ -->
      <aside
        id="ontology-sidebar"
        class="ontology-sidebar lg:sticky lg:top-[5.5rem] lg:max-h-[calc(100vh-7rem)] flex flex-col bp-crosshair bg-paper-soft border border-rule rounded-md overflow-hidden lg:block"
        data-open="false"
      >
        <!-- Header -->
        <header class="px-4 py-3 border-b border-rule bg-paper-raised">
          <div class="flex items-center justify-between mb-2">
            <span class="bp-coord">§ Ontology</span>
            <span class="bp-tally">
              <span class="bp-tally__current" id="ontology-sidebar-visible-count">{visible.length}</span>
              <span class="bp-tally__sep">/</span>
              <span>{visible.length}</span>
            </span>
          </div>
          <div class="relative">
            <input
              type="search"
              id="ontology-sidebar-search"
              placeholder="Search entities…   ( / )"
              class="w-full pl-8 pr-7 py-1.5 text-xs border border-rule rounded bg-paper text-ink focus:outline-none focus:border-accent bp-focus-ring"
              autocomplete="off"
              aria-label="Search ontology entities"
            />
            <svg class="absolute left-2 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-ink-muted pointer-events-none" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" />
            </svg>
            <kbd id="ontology-sidebar-kbd" class="absolute right-2 top-1/2 -translate-y-1/2 text-[9px] font-mono px-1 py-0.5 border border-rule rounded bg-paper text-ink-muted pointer-events-none">/</kbd>
          </div>
        </header>

        <!-- Entity tree, grouped by ontology then type -->
        <nav class="ontology-sidebar__list flex-1 overflow-y-auto" id="ontology-sidebar-list" aria-label="Ontology entities">
          {groups.map((group) => {
            const hasActiveInGroup = group.sections.some((s) =>
              flattenTree(s.tree).some((n) => n.entity.slug === activeSlug)
            )
            return (
              <section
                class="border-b border-rule last:border-0"
                data-ontology={group.ns.prefix}
                data-collapsed={hasActiveInGroup ? 'false' : 'true'}
              >
                <!-- Ontology header (clickable to collapse) -->
                <button
                  type="button"
                  class="ontology-sidebar__family w-full px-3 py-2 sticky top-0 bg-paper-raised border-b border-rule flex items-center gap-2 z-10 hover:bg-paper text-left bp-focus-ring"
                  data-family-toggle={group.ns.prefix}
                  aria-expanded={hasActiveInGroup ? 'true' : 'false'}
                >
                  <span class={`w-2 h-2 rounded-full ${nsColor[group.ns.prefix]}`}></span>
                  <span class="font-mono text-[10px] uppercase tracking-[0.1em] text-ink-soft">{group.ns.prefix}</span>
                  <span class="text-xs text-ink-muted truncate flex-1">{group.ns.title.replace('Ontology', '').replace('Taxonomy', '').trim()}</span>
                  <span class="bp-coord">{group.totalCount}</span>
                  <svg class="w-3 h-3 text-ink-muted transition-transform" data-family-chevron viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6" /></svg>
                </button>
                <div data-family-body={group.ns.prefix} class={hasActiveInGroup ? '' : 'hidden'}>
                  {group.sections.map((section) => {
                    const flat = flattenTree(section.tree)
                    const hasActiveInSection = flat.some((n) => n.entity.slug === activeSlug)
                    return (
                      <div
                        class="ontology-sidebar__section"
                        data-section-type={section.type}
                        data-collapsed={hasActiveInSection ? 'false' : 'false'}
                      >
                        <button
                          type="button"
                          class="ontology-sidebar__section-head w-full px-3 pt-2 pb-1 flex items-center gap-2 hover:bg-paper text-left bp-focus-ring"
                          data-section-toggle={section.type}
                          aria-expanded="true"
                        >
                          <svg class="w-2.5 h-2.5 text-ink-muted transition-transform" data-section-chevron viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6" /></svg>
                          <span class="bp-coord text-ink-muted flex-1">↳ {section.label} · {section.flatCount}</span>
                        </button>
                        <ul class="pb-2" data-section-body={section.type}>
                          {flat.map((node) => {
                            const e = node.entity
                            const isActive = e.slug === activeSlug
                            const hasChildren = node.children.length > 0
                            return (
                              <li
                                class="ontology-sidebar__entity"
                                data-qname={e.qname}
                                data-label={e.label.toLowerCase()}
                                data-type={e.type}
                                data-ontology={e.ontology}
                                data-description={(e.description || '').toLowerCase()}
                              >
                                <a
                                  href={`/ontology/${e.slug}`}
                                  style={`padding-left: ${0.75 + node.depth * 0.85}rem;`}
                                  class={`group flex items-start gap-1.5 py-1 pr-3 border-l-2 transition-colors no-underline text-inherit ${
                                    isActive
                                      ? 'bg-accent-soft border-accent is-current'
                                      : 'border-transparent hover:bg-paper-raised'
                                  }`
                                  }
                                  data-active={isActive ? 'true' : 'false'}
                                  title={`${typeMeta[e.type]?.label || e.type} — ${e.qname}`}
                                >
                                  {node.depth > 0 && (
                                    <span class="text-ink-muted opacity-50 select-none" aria-hidden="true">└</span>
                                  )}
                                  <span class="flex-1 min-w-0">
                                    <span class={`block text-[11px] font-mono truncate ${isActive ? 'text-accent font-semibold' : 'text-ink group-hover:text-accent'}`}>{e.qname.split(':').slice(1).join(':')}</span>
                                    {node.depth === 0 && (
                                      <span class="block text-[10px] text-ink-muted truncate">{e.label}</span>
                                    )}
                                  </span>
                                  {hasChildren && (
                                    <span class="text-[9px] text-ink-muted opacity-60 select-none" aria-hidden="true">{node.children.length}→</span>
                                  )}
                                </a>
                              </li>
                            )
                          })}
                        </ul>
                      </div>
                    )
                  })}
                </div>
              </section>
            )
          })}
          <p class="ontology-sidebar__empty text-[10px] text-ink-muted italic px-3 py-4 text-center hidden">No matches.</p>
        </nav>

        <!-- Footer -->
        <footer class="px-3 py-2 border-t border-rule bg-paper-raised flex items-center justify-between">
          <span class="bp-coord">{namespaces.length} ontologies</span>
          <a href="/ontology/" class="text-[10px] text-accent hover:underline">Overview →</a>
        </footer>
      </aside>

      <!-- ═══ MAIN ═══ -->
      <main class="ontology-main min-w-0">
        <slot />
      </main>
    </div>
  </div>

  <script is:inline>
    (function () {
      if (window.__ontologySidebarWired) {
        window.__ontologySidebarBind && window.__ontologySidebarBind();
        return;
      }
      window.__ontologySidebarWired = true;

      function bind() {
        const input = document.getElementById('ontology-sidebar-search');
        const list = document.getElementById('ontology-sidebar-list');
        const kbd = document.getElementById('ontology-sidebar-kbd');
        const countEl = document.getElementById('ontology-sidebar-visible-count');
        const emptyEl = list && list.querySelector('.ontology-sidebar__empty');
        const sidebar = document.getElementById('ontology-sidebar');
        const toggle = document.getElementById('ontology-sidebar-toggle');
        const familyToggles = list ? list.querySelectorAll('[data-family-toggle]') : [];
        const sectionToggles = list ? list.querySelectorAll('[data-section-toggle]') : [];
        if (!input || !list) return;

        const items = Array.from(list.querySelectorAll('.ontology-sidebar__entity'));
        const sections = Array.from(list.querySelectorAll('.ontology-sidebar__section'));
        const ontologyGroups = Array.from(list.querySelectorAll('[data-ontology]'));
        let currentType = '';

        function applyFilters() {
          const q = (input.value || '').toLowerCase().trim();
          let totalVisible = 0;
          for (const item of items) {
            const label = item.getAttribute('data-label') || '';
            const qname = (item.getAttribute('data-qname') || '').toLowerCase();
            const desc = item.getAttribute('data-description') || '';
            const type = item.getAttribute('data-type') || '';
            const matchesText = !q || label.includes(q) || qname.includes(q) || desc.includes(q);
            const matchesType = !currentType || type === currentType;
            const show = matchesText && matchesType;
            item.style.display = show ? '' : 'none';
            if (show) totalVisible++;
          }
          // Hide sections and ontology groups with no visible children
          for (const section of sections) {
            const visibleChildren = section.querySelectorAll('.ontology-sidebar__entity:not([style*="display: none"])').length
            section.style.display = visibleChildren > 0 ? '' : 'none';
          }
          for (const og of ontologyGroups) {
            const visibleChildren = og.querySelectorAll('.ontology-sidebar__entity:not([style*="display: none"])').length
            og.style.display = visibleChildren > 0 ? '' : 'none';
          }
          if (countEl) countEl.textContent = String(totalVisible);
          if (emptyEl) emptyEl.classList.toggle('hidden', totalVisible > 0);
          // When searching, expand all families so results are visible
          if (q && q.length > 0) {
            familyToggles.forEach((btn) => expandFamily(btn, true));
          }
        }

        function expandFamily(btn, forceExpand) {
          const body = list.querySelector(`[data-family-body="${btn.getAttribute('data-family-toggle')}"]`);
          if (!body) return;
          const isCollapsed = btn.getAttribute('aria-expanded') === 'false';
          const shouldExpand = forceExpand != null ? forceExpand : isCollapsed;
          btn.setAttribute('aria-expanded', shouldExpand ? 'true' : 'false');
          body.classList.toggle('hidden', !shouldExpand);
          const chevron = btn.querySelector('[data-family-chevron]');
          if (chevron) chevron.style.transform = shouldExpand ? '' : 'rotate(-90deg)';
        }

        function expandSection(btn) {
          const body = list.querySelector(`[data-section-body="${btn.getAttribute('data-section-toggle')}"]`);
          if (!body) return;
          const isCollapsed = btn.getAttribute('aria-expanded') === 'false';
          const shouldExpand = !isCollapsed;
          btn.setAttribute('aria-expanded', shouldExpand ? 'true' : 'false');
          body.classList.toggle('hidden', !shouldExpand);
          const chevron = btn.querySelector('[data-section-chevron]');
          if (chevron) chevron.style.transform = shouldExpand ? '' : 'rotate(-90deg)';
        }

        // Wire family/section toggles
        familyToggles.forEach((btn) => btn.addEventListener('click', () => expandFamily(btn)));
        sectionToggles.forEach((btn) => btn.addEventListener('click', () => expandSection(btn)));

        // Mobile drawer toggle (hidden on lg+)
        if (toggle && sidebar) {
          toggle.addEventListener('click', () => {
            const open = sidebar.getAttribute('data-open') === 'true';
            sidebar.setAttribute('data-open', open ? 'false' : 'true');
            toggle.setAttribute('aria-expanded', open ? 'false' : 'true');
            const chevron = toggle.querySelector('[data-chevron]');
            if (chevron) chevron.style.transform = open ? '' : 'rotate(180deg)';
          });
        }

        // Search + keyboard shortcuts
        input.addEventListener('input', applyFilters);
        if (kbd) {
          input.addEventListener('focus', () => kbd.classList.add('hidden'));
          input.addEventListener('blur', () => { if (!input.value) kbd.classList.remove('hidden'); });
        }

        document.addEventListener('keydown', (e) => {
          if (e.key === '/' && document.activeElement !== input && !e.target.matches('input, textarea, select')) {
            e.preventDefault();
            input.focus();
          }
          if (e.key === 'Escape' && document.activeElement === input) {
            input.value = '';
            applyFilters();
            input.blur();
          }
        });

        // Scroll-spy: highlight the active entity row and scroll into view.
        // (Active is server-rendered with data-active="true". We just need to
        // make sure its family/section are expanded so it's actually visible.)
        const active = list.querySelector('[data-active="true"]');
        if (active) {
          // Expand the family and section that contain the active entity.
          const family = active.closest('[data-ontology]');
          if (family) {
            const familyToggle = family.querySelector('[data-family-toggle]');
            if (familyToggle && familyToggle.getAttribute('aria-expanded') === 'false') {
              expandFamily(familyToggle);
            }
          }
          // Scroll the active row into view (centered).
          const li = active.closest('.ontology-sidebar__entity');
          if (li) li.scrollIntoView({ block: 'center' });
        }
      }

      window.__ontologySidebarBind = bind;
      document.addEventListener('astro:page-load', bind);
      bind();
    })();
  </script>

  <style is:global>
    .ontology-layout { position: relative; padding-top: 1rem; padding-bottom: 2rem; }
    /* Sidebar is collapsed by default on mobile; lg+ always visible. */
    @media (max-width: 1023px) {
      .ontology-sidebar {
        max-height: 0;
        overflow: hidden;
        border: 0;
        padding: 0;
        margin: 0;
        transition: max-height 200ms ease-in-out;
      }
      .ontology-sidebar[data-open="true"] {
        max-height: 32rem;
        border: 1px solid var(--color-rule);
        margin-bottom: 1rem;
      }
    }
  </style>
</Base>
