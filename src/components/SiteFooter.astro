---
import { NAV_ITEMS } from '../data/nav-config'
---

<footer class="border-t border-rule bg-paper-deep">
  <div class="max-w-7xl mx-auto px-6 py-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Brand + description -->
      <div>
        <div class="flex items-center gap-2 mb-3">
          <img src="/smart-logo-light.svg" alt="" class="logo-light h-6 w-auto" />
          <img src="/smart-logo-dark.svg" alt="" class="logo-dark h-6 w-auto" />
          <span class="font-serif text-sm font-semibold">OIML SMART</span>
        </div>
        <p class="text-xs text-ink-muted leading-relaxed max-w-xs">
          Machine-actionable Recommendations for the International Organization of Legal Metrology.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-xs font-mono uppercase tracking-wider text-ink-muted mb-3">Explore</h3>
        <ul class="space-y-2">
          {NAV_ITEMS.map(item => (
            <li>
              <a
                href={item.type === 'dropdown' ? item.config.links[0].href : item.href}
                class="text-sm text-ink-soft hover:text-accent transition-colors"
              >{item.type === 'dropdown' ? item.config.label : item.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Links + social -->
      <div>
        <h3 class="text-xs font-mono uppercase tracking-wider text-ink-muted mb-3">Programme</h3>
        <ul class="space-y-2 mb-4">
          <li><a href="/about/what-is-smart" class="text-sm text-ink-soft hover:text-accent transition-colors">About OIML SMART</a></li>
          <li><a href="/pilot" class="text-sm text-ink-soft hover:text-accent transition-colors">Pilot programme</a></li>
          <li><a href="/about/contact" class="text-sm text-ink-soft hover:text-accent transition-colors">Contact</a></li>
        </ul>
        <a href="https://github.com/oimlsmart" class="inline-flex items-center gap-2 text-sm text-ink-soft hover:text-accent transition-colors" aria-label="OIML SMART on GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="shrink-0">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
          </svg>
          <span>GitHub</span>
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-rule-soft flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-ink-muted text-center sm:text-left">
        A programme of the <a href="https://www.oiml.org" class="text-accent hover:underline">International Organization of Legal Metrology</a>, delivered by <a href="https://www.ribose.com" class="text-accent hover:underline">Ribose</a>
      </p>
      <p class="text-xs text-ink-muted whitespace-nowrap">Content © OIML · Code © Ribose</p>
    </div>
  </div>
</footer>
