---
import { getCollection } from 'astro:content'
import { byDocsOrder } from '../lib/docs-sort'

const SECTION_ORDER = ['guides', 'arch', 'workflow', 'specifications', 'ref'] as const
const SECTION_LABELS: Record<string, string> = {
  guides: 'Guides',
  arch: 'Architecture',
  workflow: 'Workflow',
  specifications: 'Specs',
  ref: 'Reference',
}

const allDocs = await getCollection('docs')
const currentPath = Astro.url.pathname

const sections = SECTION_ORDER
  .filter(s => allDocs.some(d => d.id.startsWith(s + '/')))
  .map(s => {
    const pages = allDocs
      .filter(d => d.id.startsWith(s + '/'))
      .sort(byDocsOrder)
    return { key: s, label: SECTION_LABELS[s], pages }
  })
---

<nav class="text-[0.8125rem] pb-8">
  {sections.map(section => (
    <div class="mb-6">
      <h3 class="font-mono text-[0.6875rem] font-semibold tracking-[0.1em] uppercase text-ink-muted m-0 mb-1.5 pl-2.5">{section.label}</h3>
      <ul class="list-none p-0 m-0">
        {section.pages.map(page => {
          const href = `/docs/${page.id}`
          const active = currentPath === href + '/' || currentPath === href
          return (
            <li>
              <a
                href={href}
                class={`block py-1 px-2.5 rounded no-underline text-[0.8125rem] leading-[1.35] transition-colors ${active ? 'text-accent font-semibold bg-accent-soft' : 'text-ink-soft hover:text-accent hover:bg-accent-soft'}`}
              >
                {page.data.shortTitle || page.data.title || page.id.split('/').pop()}
              </a>
            </li>
          )
        })}
      </ul>
    </div>
  ))}
</nav>
