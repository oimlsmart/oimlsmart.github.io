---
import { getCollection } from 'astro:content'

const SECTION_ORDER = ['guides', 'arch', 'workflow', 'specifications', 'ref'] as const
const SECTION_LABELS: Record<string, string> = {
  guides: 'Guides',
  arch: 'Architecture',
  workflow: 'Workflow',
  specifications: 'Specs',
  ref: 'Reference',
}

const allDocs = await getCollection('docs')
const currentPath = Astro.url.pathname

const sections = SECTION_ORDER
  .filter(s => allDocs.some(d => d.id.startsWith(s + '/')))
  .map(s => {
    const pages = allDocs
      .filter(d => d.id.startsWith(s + '/'))
      .sort((a, b) => {
        const ao = (a.data as any).order ?? 999
        const bo = (b.data as any).order ?? 999
        if (ao !== bo) return ao - bo
        return a.id.localeCompare(b.id)
      })
    return { key: s, label: SECTION_LABELS[s], pages }
  })
---

<nav class="sb">
  {sections.map(section => (
    <div class="sb-group">
      <h3 class="sb-heading">{section.label}</h3>
      <ul class="sb-list">
        {section.pages.map(page => {
          const href = `/docs/${page.id}`
          const active = currentPath === href + '/' || currentPath === href
          return (
            <li>
              <a href={href} class={active ? 'sb-link sb-active' : 'sb-link'}>
                {page.data.shortTitle || page.data.title || page.id.split('/').pop()}
              </a>
            </li>
          )
        })}
      </ul>
    </div>
  ))}
</nav>

<style>
.sb {
  font-size: 0.8125rem;
  padding-bottom: 2rem;
}
.sb-group { margin-bottom: 1.5rem; }
.sb-heading {
  font-family: var(--vp-font-family-mono);
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-muted);
  margin: 0 0 0.375rem;
  padding-left: 0.625rem;
}
.sb-list { list-style: none; padding: 0; margin: 0; }
.sb-link {
  display: block;
  padding: 0.25rem 0.625rem;
  border-radius: 4px;
  color: var(--ink-soft);
  text-decoration: none;
  font-size: 0.8125rem;
  line-height: 1.35;
  transition: color 0.1s, background 0.1s;
}
.sb-link:hover {
  color: var(--accent);
  background: var(--accent-soft);
}
.sb-active {
  color: var(--accent);
  font-weight: 600;
  background: var(--accent-soft);
}
</style>