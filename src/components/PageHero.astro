---
interface Props {
  title?: string
  lede?: string
  description?: string
  eyebrow?: string
  anchor?: string
  align?: 'left' | 'center'
}

const { title, lede, description, eyebrow, anchor = '§', align = 'left' } = Astro.props
const displayLede = lede ?? description
const alignClass = align === 'center' ? 'text-center mx-auto items-center' : ''
---

{title && (
  <section class={`page-hero relative pt-14 pb-10 mb-10 border-b border-rule bp-grid bp-grid--major ${alignClass}`}>
    <div class="page-hero__inner relative z-10">
      {eyebrow && (
        <div class="bp-section-anchor mb-5 max-w-3xl">
          <span class="bp-section-anchor__num">{anchor}</span>
          <span>{eyebrow}</span>
          <span class="bp-section-anchor__line"></span>
          <span class="bp-coord">OIML · SMART</span>
        </div>
      )}
      <h1 class="page-hero__title font-serif text-[clamp(2rem,5vw,3.25rem)] font-medium tracking-[-0.025em] leading-[1.05] max-w-3xl">
        {title}
      </h1>
      {displayLede && (
        <p class="page-hero__lede text-[1.125rem] leading-[1.6] text-ink-soft max-w-2xl mt-5">
          {displayLede}
        </p>
      )}
    </div>
  </section>
)}

<style>
  .page-hero {
    position: relative;
  }
  .page-hero__inner {
    /* Match the .prose-enhanced container below the hero so titles and body
       text share the same column. Keeps the layout coherent across every
       ContentPage (news, pages, etc.). */
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .page-hero::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 1px;
    background: linear-gradient(to right, var(--accent), transparent 70%);
    opacity: 0.6;
  }
</style>
