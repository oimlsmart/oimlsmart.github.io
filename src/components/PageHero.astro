---
const { title, lede, description } = Astro.props
const displayLede = lede ?? description
---

{title && (
  <div class="pt-8 pb-6 mb-6 border-b border-rule">
    <h1 class="font-serif text-[clamp(1.75rem,4vw,2.5rem)] font-semibold tracking-[-0.025em] leading-[1.15]">{title}</h1>
    {displayLede && <p class="text-[1.0625rem] leading-[1.6] text-ink-soft max-w-2xl mt-3">{displayLede}</p>}
  </div>
)}
