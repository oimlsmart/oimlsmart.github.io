---
// InternalBanner — persistent DRAFT/pilot notice at the top of every page.
// Pure HTML/CSS — no JS needed.
---

<div class="internal-banner">
  <div class="internal-banner-inner">
    <span class="badge">DRAFT</span>
    <span class="text">
      OIML SMART pilot programme · internal use only · all documents and specifications are drafts and may change without notice
    </span>
  </div>
</div>

<style>
.internal-banner {
  background: repeating-linear-gradient(45deg, #fffbeb, #fffbeb 10px, #fef3c7 10px, #fef3c7 20px);
  border-bottom: 1px solid #d97706;
  padding: 0.625rem 1rem;
  font-size: 0.75rem;
  line-height: 1.4;
  color: #78350f;
  text-align: center;
}
:global(.dark) .internal-banner {
  background: repeating-linear-gradient(45deg, #1f2937, #1f2937 10px, #111827 10px, #111827 20px);
  color: #fde68a;
}
.internal-banner-inner {
  max-width: 80rem;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  justify-content: center;
}
.badge {
  flex-shrink: 0;
  background: #d97706;
  color: white;
  font-family: monospace;
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  padding: 0.125rem 0.5rem;
  border-radius: 2px;
}
</style>