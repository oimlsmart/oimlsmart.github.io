{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "date": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "number"
        }
      ]
    },
    "author": {
      "default": "OIML SMART team",
      "type": "string"
    },
    "summary": {
      "default": "",
      "type": "string"
    },
    "draft": {
      "default": true,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date"
  ]
}