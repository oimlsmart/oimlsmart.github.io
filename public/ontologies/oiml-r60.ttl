oiml-r60:form-form-6-18 rdf:type owl:NamedIndividual , oiml:TestReportForm ;
  rdfs:label "Conducted EMC"@en .

oiml-r60:form-form-6-19-1 rdf:type owl:NamedIndividual , oiml:TestReportForm ;
  rdfs:label "Span stability (C/D)"@en .

oiml-r60:form-form-6-19-2 rdf:type owl:NamedIndividual , oiml:TestReportForm ;
  rdfs:label "Span stability (B)"@en .

oiml-r60:form-table-6-19-3 rdf:type owl:NamedIndividual , oiml:TestReportForm ;
  rdfs:label "Span stability summary"@en .

#################################################################
#    R 60 Property Assertions — Standard Structure
#################################################################

oiml-r60:R-60 oiml:hasPart oiml-r60:part-1 , oiml-r60:part-2 , oiml-r60:part-3 .

oiml-r60:part-1 oiml:hasRequirementsClass
  oiml-r60:classification-rc , oiml-r60:metrological-rc ,
  oiml-r60:electronic-rc , oiml-r60:technical-rc ,
  oiml-r60:class-a-rc , oiml-r60:class-b-rc ,
  oiml-r60:class-c-rc , oiml-r60:class-d-rc .

oiml-r60:part-2 oiml:hasConformanceClass
  oiml-r60:metrological-cc , oiml-r60:electronic-cc , oiml-r60:examination-cc ,
  oiml-r60:class-a-cc , oiml-r60:class-b-cc ,
  oiml-r60:class-c-cc , oiml-r60:class-d-cc .

oiml-r60:part-3 oiml:hasTestReport oiml-r60:test-report .

oiml-r60:test-report oiml:hasTestReportForm
  oiml-r60:form-sec-4-1 , oiml-r60:form-sec-4-2 , oiml-r60:form-sec-4-3 ,
  oiml-r60:form-sec-4-4 , oiml-r60:form-sec-4-5 , oiml-r60:form-sec-4-6 ,
  oiml-r60:form-sec-4-7 , oiml-r60:form-sec-4-8 , oiml-r60:form-sec-4-9 ,
  oiml-r60:form-sec-4-10 , oiml-r60:form-sec-4-11 ,
  oiml-r60:form-sec-5-1 , oiml-r60:form-sec-5-2 , oiml-r60:form-sec-5-3 ,
  oiml-r60:form-sec-5-4 ,
  oiml-r60:form-table-6-3 , oiml-r60:form-table-6-4 , oiml-r60:form-table-6-5 ,
  oiml-r60:form-table-6-6 , oiml-r60:form-table-6-7 , oiml-r60:form-table-6-8 ,
  oiml-r60:form-table-6-9 ,
  oiml-r60:form-table-6-10-1a , oiml-r60:form-table-6-10-1b ,
  oiml-r60:form-table-6-10-1c , oiml-r60:form-table-6-10-1d ,
  oiml-r60:form-table-6-10-1e , oiml-r60:form-table-6-10-2 ,
  oiml-r60:form-form-6-11 , oiml-r60:form-form-6-12 , oiml-r60:form-form-6-13 ,
  oiml-r60:form-form-6-14-1 , oiml-r60:form-form-6-14-2 , oiml-r60:form-form-6-15 ,
  oiml-r60:form-form-6-16-1 , oiml-r60:form-form-6-16-2-1 , oiml-r60:form-form-6-16-2-2 ,
  oiml-r60:form-form-6-16-3 , oiml-r60:form-form-6-17-1 , oiml-r60:form-form-6-17-2 ,
  oiml-r60:form-form-6-18 , oiml-r60:form-form-6-19-1 , oiml-r60:form-form-6-19-2 ,
  oiml-r60:form-table-6-19-3 .

#################################################################
#    R 60 Individuals — Classification Values (SKOS)
#################################################################

oiml-r60:accuracy-A rdf:type owl:NamedIndividual , oiml-r60:AccuracyClass , skos:Concept ;
  rdfs:label "Accuracy Class A"@en ;
  skos:prefLabel "A"@en ;
  skos:inScheme oiml-r60:accuracy-classes .

oiml-r60:accuracy-B rdf:type owl:NamedIndividual , oiml-r60:AccuracyClass , skos:Concept ;
  rdfs:label "Accuracy Class B"@en ;
  skos:prefLabel "B"@en ;
  skos:inScheme oiml-r60:accuracy-classes .

oiml-r60:accuracy-C rdf:type owl:NamedIndividual , oiml-r60:AccuracyClass , skos:Concept ;
  rdfs:label "Accuracy Class C"@en ;
  skos:prefLabel "C"@en ;
  skos:inScheme oiml-r60:accuracy-classes .

oiml-r60:accuracy-D rdf:type owl:NamedIndividual , oiml-r60:AccuracyClass , skos:Concept ;
  rdfs:label "Accuracy Class D"@en ;
  skos:prefLabel "D"@en ;
  skos:inScheme oiml-r60:accuracy-classes .

oiml-r60:accuracy-classes rdf:type skos:ConceptScheme ;
  rdfs:label "OIML R 60 Accuracy Classes"@en ;
  skos:hasTopConcept oiml-r60:accuracy-A , oiml-r60:accuracy-B , oiml-r60:accuracy-C , oiml-r60:accuracy-D .

oiml-r60:humidity-CH rdf:type owl:NamedIndividual , oiml-r60:HumidityClass , skos:Concept ;
  rdfs:label "Humidity Class CH"@en ;
  skos:prefLabel "CH"@en ;
  skos:inScheme oiml-r60:humidity-classes .

oiml-r60:humidity-NH rdf:type owl:NamedIndividual , oiml-r60:HumidityClass , skos:Concept ;
  rdfs:label "Humidity Class NH"@en ;
  skos:prefLabel "NH"@en ;
  skos:inScheme oiml-r60:humidity-classes .

oiml-r60:humidity-SH rdf:type owl:NamedIndividual , oiml-r60:HumidityClass , skos:Concept ;
  rdfs:label "Humidity Class SH"@en ;
  skos:prefLabel "SH"@en ;
  skos:inScheme oiml-r60:humidity-classes .

oiml-r60:humidity-classes rdf:type skos:ConceptScheme ;
  rdfs:label "OIML R 60 Humidity Classes"@en ;
  skos:hasTopConcept oiml-r60:humidity-CH , oiml-r60:humidity-NH , oiml-r60:humidity-SH .

oiml-r60:tech-analogue-passive rdf:type owl:NamedIndividual , oiml-r60:Technology , skos:Concept ;
  rdfs:label "Analogue Passive"@en ;
  skos:prefLabel "analogue-passive"@en ;
  skos:inScheme oiml-r60:technology-classes .

oiml-r60:tech-analogue-active rdf:type owl:NamedIndividual , oiml-r60:Technology , skos:Concept ;
  rdfs:label "Analogue Active"@en ;
  skos:prefLabel "analogue-active"@en ;
  skos:inScheme oiml-r60:technology-classes .

oiml-r60:tech-digital rdf:type owl:NamedIndividual , oiml-r60:Technology , skos:Concept ;
  rdfs:label "Digital"@en ;
  skos:prefLabel "digital"@en ;
  skos:inScheme oiml-r60:technology-classes .

oiml-r60:technology-classes rdf:type skos:ConceptScheme ;
  rdfs:label "OIML R 60 Technology Classes"@en ;
  skos:hasTopConcept oiml-r60:tech-analogue-passive , oiml-r60:tech-analogue-active , oiml-r60:tech-digital .

#################################################################
#    R 60 Individuals — Applicability Constraints
#################################################################

oiml-r60:app-accuracy-a rdf:type owl:NamedIndividual , oiml:Applicability ;
  rdfs:label "Accuracy class A only"@en ;
  skos:definition "Applies only to accuracy class A load cells."@en .

oiml-r60:app-accuracy-b rdf:type owl:NamedIndividual , oiml:Applicability ;
  rdfs:label "Accuracy class B only"@en ;
  skos:definition "Applies only to accuracy class B load cells."@en .

oiml-r60:app-accuracy-c rdf:type owl:NamedIndividual , oiml:Applicability ;
  rdfs:label "Accuracy class C only"@en ;
  skos:definition "Applies only to accuracy class C load cells."@en .

oiml-r60:app-accuracy-d rdf:type owl:NamedIndividual , oiml:Applicability ;
  rdfs:label "Accuracy class D only"@en ;
  skos:definition "Applies only to accuracy class D load cells."@en .

oiml-r60:app-electronic-tech rdf:type owl:NamedIndividual , oiml:Applicability ;
  rdfs:label "Electronic technology (analogue-active, digital)"@en ;
  skos:definition "Applies to analogue-active and digital technology load cells."@en .
